---
layout: base.njk
title: ReviewRadar Historical Data
---
<script>document.body.classList.add('rr-app-page');</script>

<aside class="rr-sidebar">
  <a href="/dashboard" class="rr-sidebar-icon" title="Dashboard">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="1" y="1" width="6" height="6" rx="1.5" fill="currentColor"/><rect x="9" y="1" width="6" height="6" rx="1.5" fill="currentColor" opacity="0.4"/><rect x="1" y="9" width="6" height="6" rx="1.5" fill="currentColor" opacity="0.4"/><rect x="9" y="9" width="6" height="6" rx="1.5" fill="currentColor" opacity="0.4"/></svg>
  </a>
  <a href="/reports" class="rr-sidebar-icon" title="Reports">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="2" y="9" width="3" height="5" rx="1" fill="currentColor"/><rect x="6.5" y="5" width="3" height="9" rx="1" fill="currentColor"/><rect x="11" y="2" width="3" height="12" rx="1" fill="currentColor"/></svg>
  </a>
  <a href="/historical-data" class="rr-sidebar-icon active" title="Historical Data">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
  </a>
  <div class="rr-sidebar-spacer"></div>
  <a href="/settings" class="rr-sidebar-icon" title="Settings">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9"/></svg>
  </a>
</aside>

<div class="rr-main">

  <!-- Header -->
  <div class="rr-header-row">
    <div class="rr-radar-bg" style="background:var(--ink-light);">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--cyan)" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
    </div>
    <div style="flex:1;min-width:0;">
      <h1 class="rr-header-title">Historical Data</h1>
      <p class="rr-header-sub" id="histSubtitle">Pull request activity over time</p>
    </div>
    <div class="rr-header-actions">
      <button id="histLoadBtn" onclick="loadHistoricalData()" class="rr-btn-primary">
        <svg id="histLoadIcon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.3"/></svg>
        <span id="histLoadSpinner" class="loading hidden"></span>
        Load Data
      </button>
    </div>
  </div>

  <!-- Date Filter Bar -->
  <div style="display:flex;gap:12px;align-items:flex-end;margin-bottom:16px;flex-wrap:wrap;">
    <div>
      <label style="display:block;font-family:'Space Mono',monospace;font-size:10px;text-transform:uppercase;letter-spacing:0.06em;color:var(--muted);margin-bottom:6px;">From</label>
      <input type="date" id="histDateFrom" class="rounded-lg border border-border-subtle bg-ink-light px-3 py-2 font-space-mono text-[13px] text-text-primary focus:border-cyan focus:outline-none" style="color-scheme:dark;">
    </div>
    <div>
      <label style="display:block;font-family:'Space Mono',monospace;font-size:10px;text-transform:uppercase;letter-spacing:0.06em;color:var(--muted);margin-bottom:6px;">To</label>
      <input type="date" id="histDateTo" class="rounded-lg border border-border-subtle bg-ink-light px-3 py-2 font-space-mono text-[13px] text-text-primary focus:border-cyan focus:outline-none" style="color-scheme:dark;">
    </div>
    <label style="display:flex;align-items:center;gap:6px;font-family:'Space Mono',monospace;font-size:12px;color:var(--muted);cursor:pointer;padding-bottom:2px;">
      <input type="checkbox" id="histAllTime" onchange="toggleAllTime()" class="accent-cyan">
      All time
    </label>
  </div>

  <!-- Status bar -->
  <div id="histStatus" style="display:none;font-family:'Space Mono',monospace;font-size:12px;color:var(--muted);margin-bottom:12px;padding:8px 12px;border-radius:6px;background:rgba(255,255,255,0.03);border:0.5px solid var(--border-faint);"></div>

  <!-- No data / no PAT state -->
  <div id="histNoData" style="display:none;text-align:center;padding:80px 32px;">
    <div style="width:56px;height:56px;border-radius:50%;background:var(--cyan-dim);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
      <svg style="color:var(--cyan);" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
    </div>
    <p style="font-family:'Space Mono',monospace;font-size:14px;color:var(--text-primary);margin-bottom:8px;">No data found</p>
    <p style="font-size:13px;color:var(--muted);">Select a date range and click Load Data to fetch historical PR data.</p>
  </div>

  <!-- No PAT state -->
  <div id="histNoPat" style="display:none;text-align:center;padding:80px 32px;">
    <div style="width:56px;height:56px;border-radius:50%;background:rgba(245,158,11,0.1);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
      <svg style="color:var(--amber);" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
    </div>
    <p style="font-family:'Space Mono',monospace;font-size:14px;color:var(--text-primary);margin-bottom:8px;">No GitHub token configured</p>
    <p style="font-size:13px;color:var(--muted);margin-bottom:20px;">Add your Personal Access Token in Settings to fetch live data.</p>
    <a href="/settings" class="rr-btn-primary" style="text-decoration:none;">Go to Settings</a>
  </div>

  <!-- No repos state -->
  <div id="histNoRepos" style="display:none;text-align:center;padding:80px 32px;">
    <div style="width:56px;height:56px;border-radius:50%;background:var(--cyan-dim);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
      <svg style="color:var(--cyan);" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
    </div>
    <p style="font-family:'Space Mono',monospace;font-size:14px;color:var(--text-primary);margin-bottom:8px;">No repositories selected</p>
    <p style="font-size:13px;color:var(--muted);margin-bottom:20px;">Add repositories in Settings to start tracking pull requests.</p>
    <a href="/settings" class="rr-btn-primary" style="text-decoration:none;">Add Repositories →</a>
  </div>

  <!-- Typing Loader -->
  <div id="typingLoader" style="display:none;align-items:center;justify-content:center;padding:80px 32px;flex-direction:column;">
    <img src="/assets/typing-dev.svg" width="240" height="160" alt="Loading..." style="max-width:100%;height:auto;">
    <p style="font-family:'Space Mono',monospace;font-size:12px;color:var(--muted);margin-top:16px;letter-spacing:0.05em;">Fetching historical data...<br>Please be patient, this could take some time if you have been busy!</p>
  </div>

  <!-- Main content -->
  <div id="histGrid" style="display:none;grid-template-columns:1fr;gap:16px;max-width:1200px;margin:0 auto;">

    <!-- Overview Metrics -->
    <h3 class="mb-1 font-space-mono text-[10px] font-bold uppercase tracking-wider text-white/40">Overview</h3>
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;">
      <div class="rr-stat" style="background:var(--ink-light);border:0.5px solid var(--border-faint);border-radius:12px;padding:16px;text-align:center;">
        <div style="font-family:'Space Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:0.05em;color:var(--muted);margin-bottom:8px;">Opened</div>
        <div id="metricOpened" style="font-family:'Space Mono',monospace;font-size:28px;font-weight:700;color:var(--cyan);">—</div>
      </div>
      <div class="rr-stat" style="background:var(--ink-light);border:0.5px solid var(--border-faint);border-radius:12px;padding:16px;text-align:center;">
        <div style="font-family:'Space Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:0.05em;color:var(--muted);margin-bottom:8px;">Closed</div>
        <div id="metricClosed" style="font-family:'Space Mono',monospace;font-size:28px;font-weight:700;color:var(--amber);">—</div>
      </div>
      <div class="rr-stat" style="background:var(--ink-light);border:0.5px solid var(--border-faint);border-radius:12px;padding:16px;text-align:center;">
        <div style="font-family:'Space Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:0.05em;color:var(--muted);margin-bottom:8px;">Merged</div>
        <div id="metricMerged" style="font-family:'Space Mono',monospace;font-size:28px;font-weight:700;color:var(--green);">—</div>
      </div>
      <div class="rr-stat" style="background:var(--ink-light);border:0.5px solid var(--border-faint);border-radius:12px;padding:16px;text-align:center;">
        <div style="font-family:'Space Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:0.05em;color:var(--muted);margin-bottom:8px;">Reviews</div>
        <div id="metricReviews" style="font-family:'Space Mono',monospace;font-size:28px;font-weight:700;color:var(--purple);">—</div>
      </div>
    </div>

    <!-- User Metrics -->
    <h3 class="mb-1 font-space-mono text-[10px] font-bold uppercase tracking-wider text-white/40">Activity by Person</h3>
    <div class="rr-stat" style="background:var(--ink-light);border:0.5px solid var(--border-faint);border-radius:12px;padding:20px;overflow-x:auto;">
      <table class="w-full border-collapse text-[13px]" id="histUserTable">
        <thead class="border-b border-border-faint">
          <tr>
            <th class="px-3 py-2 text-left font-space-mono text-[10px] font-semibold uppercase tracking-wider text-white/35">Person</th>
            <th class="px-3 py-2 text-center font-space-mono text-[10px] font-semibold uppercase tracking-wider text-white/35">Opened</th>
            <th class="px-3 py-2 text-center font-space-mono text-[10px] font-semibold uppercase tracking-wider text-white/35">Closed</th>
            <th class="px-3 py-2 text-center font-space-mono text-[10px] font-semibold uppercase tracking-wider text-white/35">Merged</th>
            <th class="px-3 py-2 text-center font-space-mono text-[10px] font-semibold uppercase tracking-wider text-white/35">Reviews</th>
          </tr>
        </thead>
        <tbody id="histUserTableBody"></tbody>
      </table>
    </div>

    <!-- PR Size Distribution -->
    <h3 class="mb-1 font-space-mono text-[10px] font-bold uppercase tracking-wider text-white/40">PR Size Distribution</h3>
    <div class="rr-stat" style="background:var(--ink-light);border:0.5px solid var(--border-faint);border-radius:12px;padding:20px;">
      <div id="sizeDistContainer" style="display:flex;flex-direction:column;gap:10px;"></div>
    </div>

    <!-- PR Size Details -->
    <h3 class="mb-1 font-space-mono text-[10px] font-bold uppercase tracking-wider text-white/40">PR Size Details</h3>
    <div class="rr-stat" style="background:var(--ink-light);border:0.5px solid var(--border-faint);border-radius:12px;padding:20px;overflow-x:auto;">
      <table class="w-full border-collapse text-[13px]" id="histSizeTable">
        <thead class="border-b border-border-faint">
          <tr>
            <th class="px-3 py-2 text-left font-space-mono text-[10px] font-semibold uppercase tracking-wider text-white/35">Pull Request</th>
            <th class="px-3 py-2 text-left font-space-mono text-[10px] font-semibold uppercase tracking-wider text-white/35">Author</th>
            <th class="px-3 py-2 text-center font-space-mono text-[10px] font-semibold uppercase tracking-wider text-white/35">Files</th>
            <th class="px-3 py-2 text-center font-space-mono text-[10px] font-semibold uppercase tracking-wider text-white/35">Lines</th>
            <th class="px-3 py-2 text-center font-space-mono text-[10px] font-semibold uppercase tracking-wider text-white/35">Size</th>
            <th class="px-3 py-2 text-center font-space-mono text-[10px] font-semibold uppercase tracking-wider text-white/35">Status</th>
          </tr>
        </thead>
        <tbody id="histSizeTableBody"></tbody>
      </table>
    </div>

  </div>

</div>

<script>
(function() {
  const CHART_COLORS = ['#22d3ee','#22c55e','#f59e0b','#ef4444','#8b5cf6','#06b6d4','#10b981','#f97316'];
  const SIZE_COLORS = { Small: '#22c55e', Medium: '#22d3ee', Large: '#f59e0b', Enormous: '#ef4444' };

  function formatDate(d) {
    const year = d.getFullYear();
    const month = String(d.getMonth() + 1).padStart(2, '0');
    const day = String(d.getDate()).padStart(2, '0');
    return `${year}-${month}-${day}`;
  }

  function parseDateInput(id) {
    const val = document.getElementById(id).value;
    if (!val) return null;
    const d = new Date(val);
    d.setHours(0, 0, 0, 0);
    return d;
  }

  function getDateRange() {
    const allTime = document.getElementById('histAllTime').checked;
    if (allTime) return { allTime: true };
    const start = parseDateInput('histDateFrom');
    const end = parseDateInput('histDateTo');
    if (end) end.setHours(23, 59, 59, 999);
    return { start, end, allTime: false };
  }

  function inRange(dateStr, range) {
    if (range.allTime) return true;
    if (!dateStr) return false;
    const d = new Date(dateStr);
    return d >= range.start && d <= range.end;
  }

  function setDefaultDates() {
    const now = new Date();
    const firstDay = new Date(now.getFullYear(), now.getMonth() - 1, 1);
    const lastDay = new Date(now.getFullYear(), now.getMonth(), 0);
    document.getElementById('histDateFrom').value = formatDate(firstDay);
    document.getElementById('histDateTo').value = formatDate(lastDay);
  }

  function toggleAllTime() {
    const checked = document.getElementById('histAllTime').checked;
    document.getElementById('histDateFrom').disabled = checked;
    document.getElementById('histDateTo').disabled = checked;
  }
  window.toggleAllTime = toggleAllTime;

  function setStatus(msg, isError) {
    const el = document.getElementById('histStatus');
    if (!el) return;
    el.textContent = msg;
    el.style.color = isError ? 'var(--red)' : 'var(--muted)';
    el.style.display = msg ? 'block' : 'none';
  }

  function setLoading(on) {
    const btn = document.getElementById('histLoadBtn');
    const icon = document.getElementById('histLoadIcon');
    const spinner = document.getElementById('histLoadSpinner');
    const loader = document.getElementById('typingLoader');
    const grid = document.getElementById('histGrid');
    if (btn) btn.disabled = on;
    if (icon) icon.classList.toggle('hidden', on);
    if (spinner) spinner.classList.toggle('hidden', !on);
    if (loader) loader.style.display = on ? 'flex' : 'none';
    if (grid && on) grid.style.display = 'none';
  }

  function getStoredPat() {
    return localStorage.getItem('github-pat') || '';
  }

  function getStoredRepos() {
    try {
      const v = localStorage.getItem('github-repos');
      return v ? JSON.parse(v) : [];
    } catch(e) { return []; }
  }

  function getSelectedRepos() {
    try {
      const v = localStorage.getItem('selected-repos');
      return v ? JSON.parse(v) : [];
    } catch(e) { return []; }
  }

  async function ghFetch(url, pat) {
    const res = await fetch(url, {
      headers: { Authorization: `token ${pat}`, Accept: 'application/vnd.github.v3+json' }
    });
    if (!res.ok) throw new Error(`GitHub ${res.status}: ${url}`);
    return res.json();
  }

  async function fetchRepoPRsAll(repo, pat) {
    const prs = [];
    for (let page = 1; page <= 10; page++) {
      try {
        const data = await ghFetch(
          `https://api.github.com/repos/${repo}/pulls?state=all&per_page=100&page=${page}&sort=updated&direction=desc`,
          pat
        );
        if (!Array.isArray(data) || data.length === 0) break;
        prs.push(...data);
        if (data.length < 100) break;
      } catch(e) { console.warn('Repo fetch error', repo, e.message); break; }
    }
    return prs;
  }

  async function fetchReviews(pr, pat) {
    try {
      const repoMatch = (pr.repository_url || pr.url || '').match(/repos\/([^/]+\/[^/]+)/);
      if (!repoMatch || !pr.number) return [];
      const data = await ghFetch(
        `https://api.github.com/repos/${repoMatch[1]}/pulls/${pr.number}/reviews`, pat
      );
      return Array.isArray(data) ? data : [];
    } catch(e) { return []; }
  }

  async function fetchPRFiles(pr, pat) {
    try {
      const repoMatch = (pr.repository_url || pr.url || '').match(/repos\/([^/]+\/[^/]+)/);
      if (!repoMatch || !pr.number) return [];
      const files = [];
      for (let page = 1; page <= 3; page++) {
        const data = await ghFetch(
          `https://api.github.com/repos/${repoMatch[1]}/pulls/${pr.number}/files?per_page=100&page=${page}`,
          pat
        );
        if (!Array.isArray(data) || data.length === 0) break;
        files.push(...data);
        if (data.length < 100) break;
      }
      return files;
    } catch(e) { return []; }
  }

  async function fetchBatch(items, fetchFn, label, statusFn) {
    const results = [];
    const batchSize = 10;
    for (let i = 0; i < items.length; i += batchSize) {
      const batch = items.slice(i, i + batchSize);
      const batchResults = await Promise.all(batch.map(item => fetchFn(item)));
      results.push(...batchResults);
      if (statusFn) statusFn(Math.min(i + batchSize, items.length), items.length);
      if (i + batchSize < items.length) {
        await new Promise(r => setTimeout(r, 200));
      }
    }
    return results;
  }

  async function loadHistoricalData() {
    setLoading(true);
    setStatus('');

    const pat = getStoredPat();
    const repos = getSelectedRepos().length > 0 ? getSelectedRepos() : getStoredRepos();
    const range = getDateRange();

    if (!pat) {
      setLoading(false);
      document.getElementById('histNoData').style.display = 'none';
      document.getElementById('histNoPat').style.display = 'block';
      document.getElementById('histNoRepos').style.display = 'none';
      document.getElementById('histGrid').style.display = 'none';
      return;
    }

    if (repos.length === 0) {
      setLoading(false);
      document.getElementById('histNoData').style.display = 'none';
      document.getElementById('histNoPat').style.display = 'none';
      document.getElementById('histNoRepos').style.display = 'block';
      document.getElementById('histGrid').style.display = 'none';
      return;
    }

    try {
      setStatus(`Fetching PRs from ${repos.length} repo${repos.length !== 1 ? 's' : ''}…`);
      let allPRs = [];
      for (const repo of repos) {
        const repoPRs = await fetchRepoPRsAll(repo, pat);
        allPRs.push(...repoPRs);
      }

      if (allPRs.length === 0) {
        setStatus('No PRs found', false);
        setLoading(false);
        showEmpty();
        return;
      }

      setStatus(`Fetching reviews for ${allPRs.length} PRs…`);
      const reviewsList = await fetchBatch(allPRs, pr => fetchReviews(pr, pat), 'reviews', (done, total) => {
        setStatus(`Fetched reviews ${done} / ${total}…`);
      });
      const reviewsMap = {};
      allPRs.forEach((pr, i) => { reviewsMap[pr.id] = reviewsList[i] || []; });

      setStatus(`Fetching file sizes for ${allPRs.length} PRs…`);
      const filesList = await fetchBatch(allPRs, pr => fetchPRFiles(pr, pat), 'files', (done, total) => {
        setStatus(`Fetched files ${done} / ${total}…`);
      });
      const filesMap = {};
      allPRs.forEach((pr, i) => { filesMap[pr.id] = filesList[i] || []; });

      setStatus('');
      setLoading(false);
      showData(allPRs, reviewsMap, filesMap, range);
    } catch(e) {
      console.error('Load error:', e);
      setStatus('Error: ' + e.message, true);
      setLoading(false);
      showEmpty();
    }
  }
  window.loadHistoricalData = loadHistoricalData;

  function showEmpty() {
    document.getElementById('histNoData').style.display = 'block';
    document.getElementById('histNoPat').style.display = 'none';
    document.getElementById('histNoRepos').style.display = 'none';
    document.getElementById('histGrid').style.display = 'none';
  }

  function showData(prs, reviewsMap, filesMap, range) {
    document.getElementById('histNoData').style.display = 'none';
    document.getElementById('histNoPat').style.display = 'none';
    document.getElementById('histNoRepos').style.display = 'none';
    document.getElementById('histGrid').style.display = 'grid';

    const opened = prs.filter(p => inRange(p.created_at, range));
    const closed = prs.filter(p => p.closed_at && inRange(p.closed_at, range));
    const merged = prs.filter(p => p.merged_at && inRange(p.merged_at, range));

    let totalReviews = 0;
    const reviewsByPerson = {};
    Object.values(reviewsMap).forEach(reviews => {
      reviews.forEach(r => {
        if (inRange(r.submitted_at, range)) {
          totalReviews++;
          const name = r.user?.login || 'unknown';
          reviewsByPerson[name] = (reviewsByPerson[name] || 0) + 1;
        }
      });
    });

    document.getElementById('metricOpened').textContent = opened.length;
    document.getElementById('metricClosed').textContent = closed.length;
    document.getElementById('metricMerged').textContent = merged.length;
    document.getElementById('metricReviews').textContent = totalReviews;

    const users = {};
    opened.forEach(p => {
      const name = p.user?.login || 'unknown';
      if (!users[name]) users[name] = { opened: 0, closed: 0, merged: 0, reviews: 0 };
      users[name].opened++;
    });
    closed.forEach(p => {
      const name = p.user?.login || 'unknown';
      if (!users[name]) users[name] = { opened: 0, closed: 0, merged: 0, reviews: 0 };
      users[name].closed++;
    });
    merged.forEach(p => {
      const name = p.user?.login || 'unknown';
      if (!users[name]) users[name] = { opened: 0, closed: 0, merged: 0, reviews: 0 };
      users[name].merged++;
    });
    Object.entries(reviewsByPerson).forEach(([name, count]) => {
      if (!users[name]) users[name] = { opened: 0, closed: 0, merged: 0, reviews: 0 };
      users[name].reviews = count;
    });

    const sortedUsers = Object.entries(users).sort((a, b) => {
      const scoreA = a[1].opened + a[1].reviews;
      const scoreB = b[1].opened + b[1].reviews;
      return scoreB - scoreA;
    });

    const tbody = document.getElementById('histUserTableBody');
    if (sortedUsers.length === 0) {
      tbody.innerHTML = `<tr><td colspan="5" style="padding:32px;text-align:center;color:var(--muted-dim);">No activity in selected period</td></tr>`;
    } else {
      tbody.innerHTML = sortedUsers.map(([name, stats]) => `
        <tr style="border-bottom:0.5px solid var(--border-faint);">
          <td style="padding:10px 12px;font-family:'Space Mono',monospace;font-size:12px;color:var(--text-primary);">${name}</td>
          <td style="padding:10px 12px;text-align:center;font-family:'Space Mono',monospace;font-size:12px;color:var(--cyan);">${stats.opened}</td>
          <td style="padding:10px 12px;text-align:center;font-family:'Space Mono',monospace;font-size:12px;color:var(--amber);">${stats.closed}</td>
          <td style="padding:10px 12px;text-align:center;font-family:'Space Mono',monospace;font-size:12px;color:var(--green);">${stats.merged}</td>
          <td style="padding:10px 12px;text-align:center;font-family:'Space Mono',monospace;font-size:12px;color:var(--purple);">${stats.reviews}</td>
        </tr>
      `).join('');
    }

    const sizeCategories = { Small: 0, Medium: 0, Large: 0, Enormous: 0 };
    const prSizeDetails = [];

    opened.forEach(pr => {
      const files = filesMap[pr.id] || [];
      const fileCount = files.length;
      const lineCount = files.reduce((sum, f) => sum + (f.additions || 0) + (f.deletions || 0), 0);

      let category;
      if (lineCount <= 50) category = 'Small';
      else if (lineCount <= 250) category = 'Medium';
      else if (lineCount <= 1000) category = 'Large';
      else category = 'Enormous';

      sizeCategories[category]++;
      prSizeDetails.push({
        title: pr.title || 'Untitled',
        author: pr.user?.login || 'unknown',
        files: fileCount,
        lines: lineCount,
        category,
        state: pr.merged ? 'Merged' : pr.state === 'closed' ? 'Closed' : 'Open',
        url: pr.html_url || '#'
      });
    });

    const totalSized = opened.length;
    const sizeEntries = Object.entries(sizeCategories).filter(([,v]) => v > 0);
    const maxSizeCount = Math.max(...Object.values(sizeCategories));

    const sizeContainer = document.getElementById('sizeDistContainer');
    if (sizeEntries.length === 0) {
      sizeContainer.innerHTML = '<p style="text-align:center;padding:40px;font-size:12px;color:var(--muted-dim);">No PRs opened in selected period</p>';
    } else {
      sizeContainer.innerHTML = sizeEntries.map(([cat, count]) => {
        const pct = totalSized > 0 ? Math.round((count / totalSized) * 100) : 0;
        const barWidth = maxSizeCount > 0 ? (count / maxSizeCount) * 100 : 0;
        const color = SIZE_COLORS[cat];
        return `
          <div style="display:flex;align-items:center;gap:12px;">
            <div style="font-family:'Space Mono',monospace;font-size:11px;color:var(--muted-dim);min-width:80px;text-align:right;">${cat}</div>
            <div style="flex:1;height:18px;background:${color}33;border-radius:3px;overflow:hidden;position:relative;">
              <div style="height:100%;background:${color};width:${barWidth}%;border-radius:3px;"></div>
            </div>
            <div style="font-family:'Space Mono',monospace;font-size:11px;color:var(--text-primary);min-width:50px;text-align:right;">${count}</div>
            <div style="font-family:'Space Mono',monospace;font-size:10px;color:var(--muted);min-width:36px;text-align:right;">${pct}%</div>
          </div>
        `;
      }).join('');
    }

    const sizeTbody = document.getElementById('histSizeTableBody');
    const sortedSizes = prSizeDetails.sort((a, b) => b.lines - a.lines);
    if (sortedSizes.length === 0) {
      sizeTbody.innerHTML = `<tr><td colspan="6" style="padding:32px;text-align:center;color:var(--muted-dim);">No PRs opened in selected period</td></tr>`;
    } else {
      sizeTbody.innerHTML = sortedSizes.map(pr => {
        const color = SIZE_COLORS[pr.category];
        return `
          <tr style="border-bottom:0.5px solid var(--border-faint);">
            <td style="padding:10px 12px;max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
              <a href="${pr.url}" target="_blank" style="color:var(--cyan);text-decoration:none;font-size:12px;" title="${pr.title}">${pr.title.substring(0, 60)}${pr.title.length > 60 ? '…' : ''}</a>
            </td>
            <td style="padding:10px 12px;font-family:'Space Mono',monospace;font-size:12px;color:var(--text-primary);">${pr.author}</td>
            <td style="padding:10px 12px;text-align:center;font-family:'Space Mono',monospace;font-size:12px;color:var(--text-primary);">${pr.files}</td>
            <td style="padding:10px 12px;text-align:center;font-family:'Space Mono',monospace;font-size:12px;color:var(--text-primary);">${pr.lines}</td>
            <td style="padding:10px 12px;text-align:center;">
              <span style="display:inline-block;padding:2px 8px;border-radius:4px;font-size:10px;font-weight:700;color:${color};background:${color}22;">${pr.category}</span>
            </td>
            <td style="padding:10px 12px;text-align:center;font-family:'Space Mono',monospace;font-size:11px;color:var(--muted);">${pr.state}</td>
          </tr>
        `;
      }).join('');
    }

    const repoNames = [...new Set(prs.map(p => {
      const m = (p.repository_url || '').match(/repos\/([^/]+\/[^/]+)/);
      return m ? m[1] : null;
    }).filter(Boolean))];
    const rangeLabel = range.allTime ? 'all time' : `${formatDate(range.start)} – ${formatDate(range.end)}`;
    document.getElementById('histSubtitle').textContent = `${opened.length} PRs opened · ${rangeLabel} · ${repoNames.join(', ').slice(0, 60)}${repoNames.join(', ').length > 60 ? '…' : ''}`;
  }

  setDefaultDates();
})();
</script>
