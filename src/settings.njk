---
layout: base.njk
title: ReviewRadar Settings
---
<script>document.body.classList.add('rr-app-page');</script>

<aside class="rr-sidebar">
  <a href="/dashboard" class="rr-sidebar-icon" title="Dashboard">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="1" y="1" width="6" height="6" rx="1.5" fill="currentColor"/><rect x="9" y="1" width="6" height="6" rx="1.5" fill="currentColor" opacity="0.4"/><rect x="1" y="9" width="6" height="6" rx="1.5" fill="currentColor" opacity="0.4"/><rect x="9" y="9" width="6" height="6" rx="1.5" fill="currentColor" opacity="0.4"/></svg>
  </a>
  <a href="/reports" class="rr-sidebar-icon" title="Reports">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="2" y="9" width="3" height="5" rx="1" fill="currentColor"/><rect x="6.5" y="5" width="3" height="9" rx="1" fill="currentColor"/><rect x="11" y="2" width="3" height="12" rx="1" fill="currentColor"/></svg>
  </a>
  <a href="/historical-data" class="rr-sidebar-icon" title="Historical Data">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
  </a>
  <a href="/settings" class="rr-sidebar-icon active" title="Settings">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9"/></svg>
  </a>
</aside>

<div class="rr-main">

  <!-- Header Row -->
  <div class="rr-header-row">
    <div style="height:60px;"></div>
    <div class="rr-radar-bg">
      <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
        <circle cx="20" cy="20" r="8" stroke="#22d3ee" stroke-width="1.3" stroke-opacity="0.35"/>
        <circle cx="20" cy="20" r="14" stroke="#22d3ee" stroke-width="0.9" stroke-opacity="0.18"/>
        <circle cx="20" cy="20" r="19" stroke="#22d3ee" stroke-width="0.6" stroke-opacity="0.1"/>
        <circle cx="20" cy="20" r="2" fill="#22d3ee"/>
      </svg>
    </div>
    <div style="flex:1;min-width:0;">
      <h1 class="rr-header-title">Settings</h1>
      <p class="rr-header-sub">Manage your GitHub token and repositories</p>
    </div>
  </div>

<!-- Main Content -->
<div style="max-width:900px;margin:0 auto;padding:32px;min-height:100vh;">


  <!-- GitHub Token Section -->
  <div style="margin-bottom:48px;">
    <h2 style="font-size:28px;font-weight:700;color:var(--text-primary);margin:0 0 20px 0;">GitHub Access Token</h2>

    <div style="background:var(--ink-light);border:0.5px solid var(--border-faint);border-radius:12px;padding:24px;margin-bottom:12px;">
      <div style="font-family:'Space Mono',monospace;font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--cyan);margin-bottom:12px;">Your Token</div>
      <div id="patInputSection">
        <p style="font-size:14px;color:var(--muted);line-height:1.6;margin-bottom:16px;">Enter your GitHub Personal Access Token (PAT) with <span style="font-family:'Space Mono',monospace;background:rgba(255,255,255,0.06);padding:2px 6px;border-radius:4px;color:var(--cyan);">repo</span> scope to fetch pull requests.</p>
        <input type="password" id="settingsPatInput" placeholder="ghp_xxxxxxxxxxxxxxxxxxxx"
          style="width:100%;box-sizing:border-box;border-radius:8px;border:0.5px solid var(--border-subtle);background:var(--ink-light);padding:10px 14px;font-family:'Space Mono',monospace;font-size:13px;color:var(--text-primary);margin-bottom:12px;outline:none;"
          onfocus="this.style.borderColor='var(--cyan)'" onblur="this.style.borderColor='var(--border-subtle)'"/>
        <button onclick="settingsSavePat()" class="rr-btn-primary" style="width:100%;justify-content:center;">Save Token</button>
      </div>

      <div id="patSavedSection" style="display:none;">
        <div style="display:flex;align-items:center;gap:12px;padding:16px;border-radius:8px;background:rgba(34,197,94,0.05);border:0.5px solid rgba(34,197,94,0.2);">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <div style="flex:1;">
            <p style="font-family:'Space Mono',monospace;font-size:13px;font-weight:700;color:var(--green);margin:0 0 2px 0;">Token Saved</p>
            <p style="font-size:12px;color:var(--muted);margin:0;">Your GitHub PAT is stored locally and never sent to external servers.</p>
          </div>
          <button onclick="settingsEditPat()" style="background:none;border:none;cursor:pointer;font-family:'Space Mono',monospace;font-size:12px;color:var(--cyan);padding:6px 12px;text-decoration:none;">Update</button>
        </div>
      </div>
    </div>

    <div style="background:var(--ink-light);border:0.5px solid var(--border-faint);border-radius:12px;padding:24px;">
      <div style="font-family:'Space Mono',monospace;font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--cyan);margin-bottom:12px;">How to Create a Token</div>
      <ol style="margin:0;padding-left:20px;color:var(--muted);line-height:1.8;font-size:14px;">
        <li style="margin-bottom:8px;">Go to <a href="https://github.com/settings/tokens/new" target="_blank" style="color:var(--cyan);text-decoration:none;font-weight:600;">github.com/settings/tokens/new</a></li>
        <li style="margin-bottom:8px;">Give your token a descriptive name (e.g., "ReviewRadar")</li>
        <li style="margin-bottom:8px;">Under "Scopes", select <span style="font-family:'Space Mono',monospace;background:rgba(255,255,255,0.06);padding:2px 6px;border-radius:4px;color:var(--cyan);">repo</span> scope</li>
        <li style="margin-bottom:8px;">Click "Generate token"</li>
        <li style="margin-bottom:8px;"><strong style="color:var(--text-primary);">Copy the token immediately</strong> — you won't see it again</li>
        <li>Paste it above and click "Save Token"</li>
      </ol>
    </div>
  </div>

  <!-- Repositories Section -->
  <div style="margin-bottom:48px;">
    <h2 style="font-size:28px;font-weight:700;color:var(--text-primary);margin:0 0 20px 0;">Saved Repositories</h2>

    <div style="background:var(--ink-light);border:0.5px solid var(--border-faint);border-radius:12px;padding:24px;margin-bottom:12px;">
      <div style="font-family:'Space Mono',monospace;font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--cyan);margin-bottom:12px;">Add Repository</div>
      <p style="font-size:14px;color:var(--muted);line-height:1.6;margin-bottom:16px;">Repositories are auto-discovered when you sweep. Add more manually to monitor specific repos.</p>
      <div style="display:flex;gap:8px;margin-bottom:12px;">
        <input type="text" id="addRepoInput" placeholder="owner/repo-name"
          style="flex:1;border-radius:8px;border:0.5px solid var(--border-subtle);background:var(--ink-light);padding:10px 14px;font-family:'Space Mono',monospace;font-size:13px;color:var(--text-primary);outline:none;"
          onfocus="this.style.borderColor='var(--cyan)'" onblur="this.style.borderColor='var(--border-subtle)'"
          onkeydown="if(event.key==='Enter')settingsAddRepo()"/>
        <button onclick="settingsAddRepo()" class="rr-btn-primary">Add</button>
      </div>
      <div id="settingsRepoList" style="min-height:60px;">
        <p style="font-family:'Space Mono',monospace;font-size:13px;color:var(--muted-dim);text-align:center;padding:24px;">No repositories saved yet.</p>
      </div>
    </div>

    <div style="background:var(--ink-light);border:0.5px solid var(--border-faint);border-radius:12px;padding:24px;">
      <div style="font-family:'Space Mono',monospace;font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--cyan);margin-bottom:12px;">Format</div>
      <p style="margin:0;color:var(--muted);line-height:1.7;font-size:14px;">Enter repository names in <span style="font-family:'Space Mono',monospace;background:rgba(255,255,255,0.06);padding:2px 6px;border-radius:4px;color:var(--cyan);">owner/repo-name</span> format. Example: <span style="font-family:'Space Mono',monospace;background:rgba(255,255,255,0.06);padding:2px 6px;border-radius:4px;color:var(--cyan);">github/cli</span></p>
    </div>
  </div>

  <!-- Refresh & Notifications Section -->
  <div style="margin-bottom:48px;">
    <h2 style="font-size:28px;font-weight:700;color:var(--text-primary);margin:0 0 20px 0;">Refresh & Notifications</h2>

    <div style="background:var(--ink-light);border:0.5px solid var(--border-faint);border-radius:12px;padding:24px;margin-bottom:12px;">
      <div style="font-family:'Space Mono',monospace;font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--cyan);margin-bottom:16px;">Auto-Refresh</div>
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;padding-bottom:16px;border-bottom:0.5px solid var(--border-faint);">
        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
          <input type="checkbox" id="settingsAutoRefresh" onchange="settingsToggleAutoRefresh()" style="cursor:pointer;"/>
          <span style="font-size:14px;color:var(--text-primary);">Enable auto-refresh</span>
        </label>
      </div>

      <div style="display:flex;align-items:center;gap:12px;">
        <label style="font-size:14px;color:var(--muted);">Refresh interval:</label>
        <input type="number" id="settingsRefreshInterval" min="1" max="60" value="5" onchange="settingsSaveRefreshInterval()" style="width:60px;border-radius:6px;border:0.5px solid var(--border-subtle);background:var(--ink-light);padding:8px 10px;font-family:'Space Mono',monospace;font-size:13px;color:var(--text-primary);outline:none;"/>
        <span style="font-size:14px;color:var(--muted);">minutes</span>
      </div>
    </div>

    <div style="background:var(--ink-light);border:0.5px solid var(--border-faint);border-radius:12px;padding:24px;">
      <div style="font-family:'Space Mono',monospace;font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--cyan);margin-bottom:16px;">Browser Notifications</div>
      <div style="display:flex;align-items:center;justify-content:space-between;">
        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
          <input type="checkbox" id="settingsNotifications" onchange="settingsToggleNotifications()" style="cursor:pointer;"/>
          <span style="font-size:14px;color:var(--text-primary);">Receive notifications for PR updates</span>
        </label>
      </div>
      <p style="font-size:12px;color:var(--muted);margin:12px 0 0 0;line-height:1.6;">Get browser alerts when PRs are approved or changes are requested.</p>
    </div>
  </div>

  <!-- Appearance Section -->
  <div style="margin-bottom:48px;">
    <h2 style="font-size:28px;font-weight:700;color:var(--text-primary);margin:0 0 20px 0;">Appearance</h2>

    <div style="background:var(--ink-light);border:0.5px solid var(--border-faint);border-radius:12px;padding:24px;">
      <div style="font-family:'Space Mono',monospace;font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--cyan);margin-bottom:16px;">Theme</div>
      <p style="font-size:14px;color:var(--muted);line-height:1.6;margin-bottom:16px;">Switch between dark and light mode.</p>
      <div style="display:flex;gap:10px;">
        <button id="themeDarkBtn" onclick="settingsSetTheme('dark')" class="rr-btn-ghost" style="flex:1;justify-content:center;">Dark Mode</button>
        <button id="themeLightBtn" onclick="settingsSetTheme('light')" class="rr-btn-ghost" style="flex:1;justify-content:center;">Light Mode</button>
      </div>
    </div>
  </div>

  <!-- Table Columns Section -->
  <div style="margin-bottom:48px;">
    <h2 style="font-size:28px;font-weight:700;color:var(--text-primary);margin:0 0 20px 0;">Table Columns</h2>
    <div style="background:var(--ink-light);border:0.5px solid var(--border-faint);border-radius:12px;padding:24px;">
      <div style="font-family:'Space Mono',monospace;font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--cyan);margin-bottom:16px;">Column Layout</div>
      <p style="font-size:14px;color:var(--muted);line-height:1.6;margin-bottom:16px;">Choose which columns to show and their order on the dashboard table.</p>
      <div id="settingsColumnList" style="margin-bottom:16px;"></div>
      <div style="display:flex;gap:10px;">
        <button onclick="settingsSaveColumns()" class="rr-btn-ghost" style="flex:1;justify-content:center;">Save Layout</button>
        <button onclick="settingsResetColumns()" style="flex:1;background:rgba(239,68,68,0.05);border:0.5px solid rgba(239,68,68,0.2);border-radius:8px;padding:10px 14px;font-size:14px;color:var(--red);cursor:pointer;font-family:'Space Mono',monospace;font-weight:600;">Reset to Defaults</button>
      </div>
    </div>
  </div>

  <!-- Data Management Section -->
  <div style="margin-bottom:60px;">
    <h2 style="font-size:28px;font-weight:700;color:var(--text-primary);margin:0 0 20px 0;">Data Management</h2>

    <div style="background:var(--ink-light);border:0.5px solid var(--border-faint);border-radius:12px;padding:24px;margin-bottom:12px;">
      <div style="font-family:'Space Mono',monospace;font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--cyan);margin-bottom:12px;">Clear Data</div>
      <p style="font-size:14px;color:var(--muted);line-height:1.6;margin-bottom:16px;">Clear cached data stored in your browser. Your GitHub PAT can be re-entered anytime.</p>
      <button onclick="settingsClearRepos()" class="rr-btn-ghost" style="width:100%;justify-content:center;margin-bottom:8px;">Clear saved repositories</button>
    </div>

    <div style="background:rgba(239,68,68,0.05);border:0.5px solid rgba(239,68,68,0.2);border-radius:12px;padding:24px;">
      <div style="font-family:'Space Mono',monospace;font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--red);margin-bottom:12px;">Danger Zone</div>
      <p style="font-size:14px;color:var(--muted);line-height:1.6;margin-bottom:16px;">Permanently clear all data including your PAT, repositories, cached PRs, and all settings.</p>
      <button onclick="settingsClearAll()" style="width:100%;background:rgba(239,68,68,0.1);border:0.5px solid rgba(239,68,68,0.3);border-radius:8px;padding:10px 14px;font-size:14px;color:var(--red);cursor:pointer;font-family:'Space Mono',monospace;font-weight:600;transition:all 0.15s;">Clear All Data</button>
    </div>
  </div>

  <!-- Footer -->
  <div style="border-top:0.5px solid var(--border-faint);padding-top:32px;text-align:center;color:var(--muted);font-family:'Space Mono',monospace;font-size:12px;margin-top:60px;">
    <p style="margin:0;">© 2026 ReviewRadar · GitHub PR Dashboard</p>
  </div>

</div>

</div>

<div id="settingsMsg" style="position:fixed;bottom:20px;right:20px;padding:10px 18px;border-radius:999px;font-family:'Space Mono',monospace;font-size:12px;font-weight:600;display:none;z-index:200;"></div>

<script>
(function() {
  const COLUMN_DEFS = [
    { key: 'title', label: 'Pull request' },
    { key: 'author', label: 'Author' },
    { key: 'status', label: 'Status' },
    { key: 'myaction', label: 'My Action' },
    { key: 'approvals', label: 'Approvals' },
    { key: 'comments', label: 'Comments' },
    { key: 'labels', label: 'Labels' },
    { key: 'build', label: 'Build' },
    { key: 'created', label: 'Created' },
    { key: 'updated', label: 'Updated' },
    { key: 'details', label: 'Details' },
  ];
  const DEFAULT_COLUMNS = COLUMN_DEFS.map(c => c.key);

  // Load PAT state
  const pat = localStorage.getItem('github-pat');
  if (pat) {
    document.getElementById('patInputSection').style.display = 'none';
    document.getElementById('patSavedSection').style.display = 'block';
  }

  // Load theme state — respect saved preference or system default
  const savedTheme = localStorage.getItem('reviewradar-theme');
  const prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
  const theme = savedTheme || (prefersLight ? 'light' : 'dark');
  updateThemeBtns(theme);
  if (theme === 'light') document.documentElement.classList.add('light-mode');
  else document.documentElement.classList.remove('light-mode');

  // Load refresh & notification settings
  const autoRefresh = localStorage.getItem('auto-refresh-enabled') === 'true';
  const refreshInterval = localStorage.getItem('refresh-interval') || '5';
  const notifications = localStorage.getItem('notifications-enabled') === 'true';
  
  document.getElementById('settingsAutoRefresh').checked = autoRefresh;
  document.getElementById('settingsRefreshInterval').value = refreshInterval;
  document.getElementById('settingsNotifications').checked = notifications;

  // Load repos
  renderSettingsRepos();

  // Load column config
  renderSettingsColumns();

  function updateThemeBtns(t) {
    const dark = document.getElementById('themeDarkBtn');
    const light = document.getElementById('themeLightBtn');
    if (!dark || !light) return;
    dark.style.background = t === 'dark' ? 'var(--cyan-dim)' : '';
    dark.style.borderColor = t === 'dark' ? 'var(--cyan-mid)' : '';
    dark.style.color = t === 'dark' ? 'var(--cyan)' : '';
    light.style.background = t === 'light' ? 'var(--cyan-dim)' : '';
    light.style.borderColor = t === 'light' ? 'var(--cyan-mid)' : '';
    light.style.color = t === 'light' ? 'var(--cyan)' : '';
  }

  function renderSettingsRepos() {
    const list = document.getElementById('settingsRepoList');
    const saved = JSON.parse(localStorage.getItem('github-repos') || '[]');
    if (saved.length === 0) {
      list.innerHTML = '<p style="font-family:\'Space Mono\',monospace;font-size:12px;color:var(--muted-dim);text-align:center;padding:24px;">No repositories saved yet.</p>';
      return;
    }
    list.innerHTML = saved.map(r => `
      <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 10px;border-radius:8px;margin-bottom:4px;background:rgba(255,255,255,0.03);border:0.5px solid var(--border-faint);">
        <span style="font-family:'Space Mono',monospace;font-size:12px;color:var(--text-primary);">${r}</span>
        <button onclick="settingsRemoveRepo('${r}')" style="background:none;border:none;cursor:pointer;color:var(--muted-dim);font-size:14px;padding:2px 6px;border-radius:4px;transition:color 0.15s;" onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='var(--muted-dim)'">✕</button>
      </div>
    `).join('');
  }

  // Export renderSettingsRepos to window so it can be called from other scripts
  window.renderSettingsRepos = renderSettingsRepos;

  window.settingsSavePat = function() {
    const val = document.getElementById('settingsPatInput').value.trim();
    if (!val) return showSettingsMsg('Token cannot be empty', 'error');
    if (!val.startsWith('ghp_') && !val.startsWith('github_pat_')) return showSettingsMsg('Token should start with ghp_ or github_pat_', 'error');
    localStorage.setItem('github-pat', val);
    document.getElementById('patInputSection').style.display = 'none';
    document.getElementById('patSavedSection').style.display = 'block';
    showSettingsMsg('Token saved', 'success');
  };

  window.settingsEditPat = function() {
    document.getElementById('patSavedSection').style.display = 'none';
    document.getElementById('patInputSection').style.display = 'block';
    document.getElementById('settingsPatInput').focus();
  };

  window.settingsAddRepo = function() {
    const val = document.getElementById('addRepoInput').value.trim();
    if (!val || !val.includes('/')) return showSettingsMsg('Format: owner/repo', 'error');
    const saved = JSON.parse(localStorage.getItem('github-repos') || '[]');
    if (!saved.includes(val)) {
      saved.push(val);
      localStorage.setItem('github-repos', JSON.stringify(saved));
    }
    // Auto-select newly added repos
    const selected = JSON.parse(localStorage.getItem('selected-repos') || '[]');
    if (!selected.includes(val)) {
      selected.push(val);
      localStorage.setItem('selected-repos', JSON.stringify(selected));
    }
    document.getElementById('addRepoInput').value = '';
    renderSettingsRepos();
    showSettingsMsg('Repo added', 'success');
  };

  window.settingsRemoveRepo = function(repo) {
    const saved = JSON.parse(localStorage.getItem('github-repos') || '[]');
    const updated = saved.filter(r => r !== repo);
    localStorage.setItem('github-repos', JSON.stringify(updated));
    renderSettingsRepos();
    showSettingsMsg('Repo removed', 'success');
  };

  window.settingsClearRepos = function() {
    if (!confirm('Clear all saved repositories?')) return;
    localStorage.removeItem('github-repos');
    renderSettingsRepos();
    showSettingsMsg('Repos cleared', 'success');
  };

  window.settingsClearAll = function() {
    if (!confirm('This will clear your PAT, repos, and all cached data. Continue?')) return;
    ['github-pat','github-repos','reviewradar-theme','reviewradar-prs','reviewradar-settings','auto-refresh-enabled','refresh-interval','notifications-enabled','reviewradar-columns','reviewradar-column-widths'].forEach(k => localStorage.removeItem(k));
    location.reload();
  };

  function getColumnConfig() {
    try {
      const saved = localStorage.getItem('reviewradar-columns');
      if (saved) {
        const parsed = JSON.parse(saved);
        if (Array.isArray(parsed) && parsed.length > 0) return parsed;
      }
    } catch {}
    return [...DEFAULT_COLUMNS];
  }

  function renderSettingsColumns() {
    const list = document.getElementById('settingsColumnList');
    const config = getColumnConfig();
    const availableKeys = COLUMN_DEFS.map(c => c.key);

    // Build ordered list from config, appending any missing defaults at the end
    const ordered = [];
    config.forEach(key => {
      if (availableKeys.includes(key)) ordered.push(key);
    });
    availableKeys.forEach(key => {
      if (!ordered.includes(key)) ordered.push(key);
    });

    list.innerHTML = ordered.map((key) => {
      const def = COLUMN_DEFS.find(c => c.key === key);
      const isVisible = config.includes(key);
      return `
        <div class="settings-column-row" draggable="true" data-col-key="${key}" style="display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:8px;margin-bottom:4px;background:rgba(255,255,255,0.03);border:0.5px solid var(--border-faint);cursor:grab;">
          <span class="column-drag-handle" style="cursor:grab;color:var(--muted-dim);font-size:14px;padding:2px 4px;user-select:none;" title="Drag to reorder">☰</span>
          <input type="checkbox" ${isVisible ? 'checked' : ''} onchange="settingsToggleColumn('${key}')" style="cursor:pointer;width:16px;height:16px;accent-color:var(--cyan);">
          <span style="flex:1;font-family:'Space Mono',monospace;font-size:12px;color:var(--text-primary);">${def.label}</span>
        </div>
      `;
    }).join('');

    // Attach drag-and-drop handlers
    let draggedKey = null;
    list.querySelectorAll('.settings-column-row').forEach(row => {
      row.addEventListener('dragstart', (e) => {
        draggedKey = row.dataset.colKey;
        row.style.opacity = '0.4';
        e.dataTransfer.effectAllowed = 'move';
      });

      row.addEventListener('dragend', () => {
        draggedKey = null;
        row.style.opacity = '';
        list.querySelectorAll('.settings-column-row').forEach(r => {
          r.style.borderTop = '';
          r.style.borderBottom = '';
        });
      });

      row.addEventListener('dragover', (e) => {
        e.preventDefault();
        e.dataTransfer.dropEffect = 'move';
        const rect = row.getBoundingClientRect();
        const midY = rect.top + rect.height / 2;
        if (e.clientY < midY) {
          row.style.borderTop = '2px solid var(--cyan)';
          row.style.borderBottom = '';
        } else {
          row.style.borderTop = '';
          row.style.borderBottom = '2px solid var(--cyan)';
        }
      });

      row.addEventListener('dragleave', () => {
        row.style.borderTop = '';
        row.style.borderBottom = '';
      });

      row.addEventListener('drop', (e) => {
        e.preventDefault();
        if (!draggedKey || draggedKey === row.dataset.colKey) return;

        const rect = row.getBoundingClientRect();
        const midY = rect.top + rect.height / 2;
        const dropAfter = e.clientY >= midY;

        // Rebuild order
        const currentConfig = getColumnConfig();
        const visible = new Set(currentConfig);
        let newOrder = ordered.filter(k => k !== draggedKey);
        const targetIdx = newOrder.indexOf(row.dataset.colKey);
        const insertIdx = dropAfter ? targetIdx + 1 : targetIdx;
        newOrder.splice(insertIdx, 0, draggedKey);

        // Preserve visibility: visible keys in new order, hidden after
        const newConfig = newOrder.filter(k => visible.has(k));
        localStorage.setItem('reviewradar-columns', JSON.stringify(newConfig));
        renderSettingsColumns();
      });
    });
  };

  function settingsToggleColumn(key) {
    const config = getColumnConfig();
    if (config.includes(key)) {
      const idx = config.indexOf(key);
      config.splice(idx, 1);
    } else {
      config.push(key);
    }
    localStorage.setItem('reviewradar-columns', JSON.stringify(config));
    renderSettingsColumns();
  };

  // Drag-and-drop replaced the old settingsMoveColumn function

  function settingsSaveColumns() {
    showSettingsMsg('Column layout saved', 'success');
  };

  function settingsResetColumns() {
    localStorage.removeItem('reviewradar-columns');
    localStorage.removeItem('reviewradar-column-widths');
    renderSettingsColumns();
    showSettingsMsg('Columns reset to defaults', 'success');
  };

  window.settingsSetTheme = function(t) {
    localStorage.setItem('reviewradar-theme', t);
    updateThemeBtns(t);
    if (t === 'light') document.documentElement.classList.add('light-mode');
    else document.documentElement.classList.remove('light-mode');
  };

  window.settingsToggleAutoRefresh = function() {
    const checked = document.getElementById('settingsAutoRefresh').checked;
    localStorage.setItem('auto-refresh-enabled', checked ? 'true' : 'false');
    showSettingsMsg(checked ? 'Auto-refresh enabled' : 'Auto-refresh disabled', 'success');
  };

  window.settingsSaveRefreshInterval = function() {
    const val = document.getElementById('settingsRefreshInterval').value;
    const interval = Math.max(1, Math.min(60, parseInt(val) || 5));
    localStorage.setItem('refresh-interval', interval.toString());
    document.getElementById('settingsRefreshInterval').value = interval;
    showSettingsMsg('Refresh interval updated', 'success');
  };

  window.settingsToggleNotifications = function() {
    const checked = document.getElementById('settingsNotifications').checked;
    localStorage.setItem('notifications-enabled', checked ? 'true' : 'false');
    showSettingsMsg(checked ? 'Notifications enabled' : 'Notifications disabled', 'success');
  };

  function showSettingsMsg(msg, type) {
    const el = document.getElementById('settingsMsg');
    el.textContent = msg;
    el.style.background = type === 'success' ? 'rgba(34,197,94,0.15)' : 'rgba(239,68,68,0.15)';
    el.style.border = type === 'success' ? '0.5px solid rgba(34,197,94,0.3)' : '0.5px solid rgba(239,68,68,0.3)';
    el.style.color = type === 'success' ? 'var(--green)' : 'var(--red)';
    el.style.display = 'block';
    clearTimeout(el._t);
    el._t = setTimeout(() => { el.style.display = 'none'; }, 2500);
  }

  window.renderSettingsRepos = renderSettingsRepos;
  window.renderSettingsColumns = renderSettingsColumns;
  window.settingsToggleColumn = settingsToggleColumn;
  window.settingsMoveColumn = settingsMoveColumn;
  window.settingsSaveColumns = settingsSaveColumns;
  window.settingsResetColumns = settingsResetColumns;
})();
</script>
