---
layout: base.njk
title: ReviewRadar Dashboard
---
<script>document.body.classList.add('rr-app-page');</script>

<aside class="rr-sidebar">
  <a href="/dashboard" class="rr-sidebar-icon active" title="Dashboard">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="1" y="1" width="6" height="6" rx="1.5" fill="currentColor"/><rect x="9" y="1" width="6" height="6" rx="1.5" fill="currentColor" opacity="0.4"/><rect x="1" y="9" width="6" height="6" rx="1.5" fill="currentColor" opacity="0.4"/><rect x="9" y="9" width="6" height="6" rx="1.5" fill="currentColor" opacity="0.4"/></svg>
  </a>
  <a href="/reports" class="rr-sidebar-icon" title="Reports">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="2" y="9" width="3" height="5" rx="1" fill="currentColor"/><rect x="6.5" y="5" width="3" height="9" rx="1" fill="currentColor"/><rect x="11" y="2" width="3" height="12" rx="1" fill="currentColor"/></svg>
  </a>
  <a href="/historical-data" class="rr-sidebar-icon" title="Historical Data">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
  </a>
  <a href="/settings" class="rr-sidebar-icon" title="Settings">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9"/></svg>
  </a>
</aside>

<div class="rr-main">

  <!-- Header Row -->
  <div class="rr-header-row">
    <div style="height:60px;"></div>
    <div class="rr-radar-bg">
      <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
        <circle cx="20" cy="20" r="8" stroke="#22d3ee" stroke-width="1.3" stroke-opacity="0.35"/>
        <circle cx="20" cy="20" r="14" stroke="#22d3ee" stroke-width="0.9" stroke-opacity="0.18"/>
        <circle cx="20" cy="20" r="19" stroke="#22d3ee" stroke-width="0.6" stroke-opacity="0.1"/>
        <g class="rr-radar-sweep">
          <path d="M20 20 L36 6" stroke="#22d3ee" stroke-width="1.8" stroke-linecap="round" opacity="0.9"/>
          <path d="M20 20 L36 6 A22 22 0 0 0 20 1 Z" fill="#22d3ee" fill-opacity="0.07"/>
        </g>
        <circle cx="30" cy="12" r="2.5" fill="#22d3ee" class="rr-radar-blip1"/>
        <circle cx="25" cy="26" r="1.8" fill="#22d3ee" class="rr-radar-blip2"/>
        <circle cx="20" cy="20" r="2" fill="#22d3ee"/>
      </svg>
    </div>
    <div style="flex:1;min-width:0;">
      <h1 class="rr-header-title">Review<span class="text-cyan">Radar</span></h1>
      <p class="rr-header-sub" id="sweepSubtitle">Monitor all your pull requests in real-time</p>
    </div>
    <div class="rr-header-actions">
      <button id="loadButton" onclick="loadPRs()" class="rr-btn-primary">
        <svg id="loadIcon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.3"/></svg>
        <span id="loadSpinner" class="loading hidden"></span>
        Sweep now
      </button>
    </div>
  </div>

  <!-- Toolbar: Repo selector + right controls -->
  <div class="rr-toolbar">
    <div id="repoSelector" style="flex:1;min-width:260px;position:relative;">
      <label style="display:block;font-family:'Space Mono',monospace;font-size:10px;text-transform:uppercase;letter-spacing:0.06em;color:var(--muted);margin-bottom:6px;">Repositories</label>
      <div id="repoSelectorTrigger" onclick="toggleRepoDropdown()"
        class="flex w-full cursor-pointer items-center justify-between rounded-lg border border-border-subtle bg-ink-light px-3.5 py-2.5 font-space-mono text-[13px] text-text-primary transition-colors duration-150 hover:border-cyan-mid">
        <span id="repoSelectorText">All repos</span>
        <svg class="opacity-50" width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 5L7 9L11 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>
      <div id="repoSelectorDropdown"
        class="absolute left-0 right-0 top-[calc(100%+4px)] z-[100] hidden max-h-[280px] overflow-y-auto rounded-lg border border-border-subtle bg-ink-light shadow-lg">
        <div class="sticky top-0 z-[2] border-b border-border-faint bg-ink-light p-2.5">
          <input type="text" id="repoSearch" placeholder="Search repos..." oninput="filterRepoList()" onclick="event.stopPropagation()"
            class="w-full rounded-md border border-border-faint bg-white/[0.04] px-3 py-2 font-space-mono text-xs text-text-primary focus:border-cyan focus:outline-none"/>
        </div>
        <div id="repoSelectorList" class="p-1">
          <div class="p-4 text-center font-space-mono text-xs text-white/30">No repos saved yet. Load PRs to discover repos.</div>
        </div>
        <div class="flex gap-2 border-t border-border-faint p-2">
          <button onclick="selectAllRepos()" class="flex-1 rounded-md border border-border-faint bg-surface px-2.5 py-1.5 font-space-mono text-[11px] text-white/60 transition-all duration-150 hover:bg-white/[0.06] hover:text-text-primary">Select All</button>
          <button onclick="clearRepoSelection()" class="flex-1 rounded-md border border-border-faint bg-surface px-2.5 py-1.5 font-space-mono text-[11px] text-white/60 transition-all duration-150 hover:bg-white/[0.06] hover:text-text-primary">Clear</button>
        </div>
      </div>
    </div>
    <div class="rr-toolbar-right">
      <span id="refreshStatus" style="font-size:11px;color:var(--muted-dim);font-family:'Space Mono',monospace;">—</span>
      <span id="changesNotif" onclick="clearChangesNotif()" title="Click to dismiss"
        class="hidden cursor-pointer items-center gap-1 rounded-full border border-cyan-mid bg-cyan-dim px-3 py-1 font-space-mono text-[11px] font-semibold text-cyan">
        🔔 <span id="changesCount">0</span>
      </span>
    </div>
  </div>

  <!-- Stats Grid -->
  <div id="statsContainer" class="rr-stats" style="display:none;">
    <div class="rr-stat active" data-filter="all" onclick="setFilter('all')">
      <div class="rr-stat-label">Total PRs</div>
      <div id="totalCount" class="rr-stat-val" style="color:var(--cyan);">0</div>
      <div class="rr-stat-sub" style="color:rgba(34,211,238,0.5);">on radar</div>
    </div>
    <div class="rr-stat" data-filter="owned" onclick="setFilter('owned')">
      <div class="rr-stat-label">Mine</div>
      <div id="statMine" class="rr-stat-val" style="color:var(--purple);">0</div>
      <div class="rr-stat-sub" style="color:rgba(168,85,247,0.5);">authored by you</div>
    </div>
    <div class="rr-stat" data-filter="needs-attention" onclick="setFilter('needs-attention')">
      <div class="rr-stat-label">Needs attention</div>
      <div id="statNeedsAttention" class="rr-stat-val" style="color:var(--amber);">0</div>
      <div class="rr-stat-sub" style="color:rgba(245,158,11,0.5);">awaiting you</div>
    </div>
    <div class="rr-stat" data-filter="approved" onclick="setFilter('approved')">
      <div class="rr-stat-label">Approved</div>
      <div id="statApproved" class="rr-stat-val" style="color:var(--green);">0</div>
      <div class="rr-stat-sub" style="color:rgba(34,197,94,0.5);">Ready for QA / Merge</div>
    </div>
    <div class="rr-stat" data-filter="blocked" onclick="setFilter('blocked')">
      <div class="rr-stat-label">Blocked</div>
      <div id="statBlocked" class="rr-stat-val" style="color:var(--red);">0</div>
      <div class="rr-stat-sub" style="color:rgba(239,68,68,0.5);">build failing</div>
    </div>
  </div>

  <!-- Filter Pills -->
  <div id="filterControls" class="rr-filters" style="display:none;">
    <span id="activeFilterPill" style="display:none;"></span>
    <div style="flex:1;"></div>
    <button class="rr-sort-label" onclick="clearSort()">Sort: Updated ↓</button>
  </div>

  <!-- Typing Loader -->
  <div id="typingLoader" style="display:none;align-items:center;justify-content:center;padding:80px 32px;flex-direction:column;">
    <img src="/assets/typing-dev.svg" width="240" height="160" alt="Loading..." style="max-width:100%;height:auto;">
    <p style="font-family:'Space Mono',monospace;font-size:12px;color:var(--muted);margin-top:16px;letter-spacing:0.05em;">Sweeping repositories...</p>
  </div>

  <!-- PR Table -->
  <div class="rr-table-wrap">
    <table id="prTable">
      <thead>
        <tr>
          <th class="sortable rr-title-header" onclick="sortTable('title')">Pull request</th>
          <th class="sortable rr-col-narrow" onclick="sortTable('author')" style="width: 45px;">Author</th>
          <th class="sortable rr-col-narrow" onclick="sortTable('status')" style="width: 100px;">Status</th>
          <th class="sortable rr-col-narrow" onclick="sortTable('myaction')" style="width: 45px;">My Action</th>
          <th class="sortable rr-col-narrow" onclick="sortTable('approvals')" style="width: 75px;">Approvals</th>
          <th class="sortable rr-col-narrow" onclick="sortTable('comments')" style="width: 75px;">Comments</th>
          <th class="sortable rr-col-narrow" onclick="sortTable('labels')" style="width: 130px;">Labels</th>
          <th class="sortable" onclick="sortTable('buildStatus')" style="width: 70px;">Build</th>
          <th class="sortable rr-col-narrow" onclick="sortTable('created')" style="width: 60px;">Created</th>
          <th class="sortable rr-col-narrow" onclick="sortTable('updated')" style="width: 60px;">Updated</th>
          <th class="rr-col-narrow" style="width: 45px;"></th>
        </tr>
      </thead>
      <tbody id="prTableBody">
        <tr>
          <td colspan="20" style="padding:64px 32px;text-align:center;color:var(--muted-dim);">
            <div style="margin:0 auto 16px;width:48px;height:48px;border-radius:50%;background:var(--cyan-dim);display:flex;align-items:center;justify-content:center;">
              <svg style="color:var(--cyan);" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
            </div>
            <p style="font-family:'Space Mono',monospace;font-size:13px;color:var(--text-primary);margin-bottom:6px;">Loading saved settings...</p>
          </td>
        </tr>
      </tbody>
    </table>
  </div>

</div>

<!-- Status Report Modal -->
<div id="statusReportBackdrop" onclick="closeStatusReport()"
  class="fixed inset-0 z-[1000] hidden bg-black/70 opacity-0 transition-opacity duration-200"
  style="display:none;">
  <div class="flex min-h-full items-center justify-center p-4">
    <div id="statusReportModal" onclick="event.stopPropagation()"
      class="relative w-full max-w-[640px] scale-95 rounded-2xl border border-white/[0.08] bg-ink-light p-6 shadow-2xl opacity-0 transition-all duration-200">
      <button onclick="closeStatusReport()"
        class="absolute right-4 top-4 inline-flex h-8 w-8 items-center justify-center rounded-full text-white/30 transition-colors hover:bg-white/[0.06] hover:text-white/60">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      <div class="mb-6 text-center">
        <div class="mx-auto mb-3 flex h-10 w-10 items-center justify-center rounded-full bg-cyan/10">
          <svg class="h-5 w-5 text-cyan" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.21 15.89A10 10 0 1 1 8 2.83"/><path d="M22 12A10 10 0 0 0 12 2v10z"/></svg>
        </div>
        <h2 class="font-space-mono text-sm font-bold tracking-tight text-text-primary">Status Report</h2>
        <p class="mt-1 text-[12px] text-white/40">Current snapshot of your pull requests</p>
      </div>
      <div id="statusReportContent" class="space-y-6"></div>
    </div>
  </div>
</div>

<!-- Settings Modal -->
<div id="settingsModalBackdrop" onclick="closeSettingsModal()"
  class="fixed inset-0 z-[1000] hidden bg-black/70 opacity-0 transition-opacity duration-200"
  style="display:none;">
  <div class="flex min-h-full items-center justify-center p-4">
    <div id="settingsModal" onclick="event.stopPropagation()"
      class="relative w-full max-w-[380px] scale-95 rounded-2xl border border-white/[0.08] bg-ink-light p-4 shadow-2xl opacity-0 transition-all duration-200">
      <button onclick="closeSettingsModal()"
        class="absolute right-3 top-3 inline-flex h-8 w-8 items-center justify-center rounded-full text-white/30 transition-colors hover:bg-white/[0.06] hover:text-white/60">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      <div class="mb-6 text-center">
        <div class="mx-auto mb-3 flex h-10 w-10 items-center justify-center rounded-full bg-cyan/10">
          <svg class="h-5 w-5 text-cyan" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
        </div>
        <h2 class="font-space-mono text-sm font-bold tracking-tight text-text-primary">GitHub Access Token</h2>
        <p class="mt-1 text-[12px] text-white/40">Required to fetch your pull requests</p>
      </div>
      <div id="modalPatInputWrap" class="space-y-3">
        <div>
          <label class="mb-3 block font-space-mono text-[10px] font-semibold uppercase tracking-wider text-white/40">Personal Access Token</label>
          <input type="password" id="patInput" placeholder="ghp_xxxxxxxxxxxxxxxxxxxx"
            class="w-full rounded-lg border border-border-subtle bg-surface px-3.5 py-2.5 font-space-mono text-[13px] text-text-primary transition-colors duration-150 placeholder:text-white/20 focus:border-cyan focus:outline-none mb-3"/>
        </div>
        <button onclick="savePatToken()"
          class="w-full cursor-pointer rounded-lg border-none bg-cyan py-2.5 font-space-mono text-sm font-bold text-ink-light transition-all duration-150 hover:opacity-90">Save Token</button>
        <div class="rounded-lg border border-border-faint bg-surface/50 p-3">
          <p class="mb-3 mt-3 font-space-mono text-[11px] font-semibold text-white/50">How to create a token:</p>
          <ol class="space-y-1 font-space-mono text-[11px] text-white/40">
            <li>1. Go to <a class="text-cyan no-underline hover:underline" href="https://github.com/settings/tokens/new" target="_blank">github.com/settings/tokens/new</a></li>
            <li>2. Select <code class="rounded bg-white/[0.06] px-1 py-0.5 text-cyan">repo</code> scope</li>
            <li>3. Copy and paste the token above</li>
          </ol>
        </div>
      </div>
      <div id="modalPatSavedWrap" class="hidden flex-col items-center gap-3 text-center">
        <div class="flex h-10 w-10 items-center justify-center rounded-full bg-green/10">
          <svg class="h-5 w-5 text-green" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div>
          <p class="font-space-mono text-sm font-bold text-text-primary">Token Saved</p>
          <p class="mt-0.5 text-[12px] text-white/40">Your GitHub PAT is securely stored</p>
        </div>
        <button onclick="showPatInput()"
          class="cursor-pointer rounded-lg border border-border-faint bg-surface px-4 py-2 font-space-mono text-[11px] text-white/60 transition-all duration-150 hover:bg-white/[0.06] hover:text-text-primary">Update Token</button>
      </div>
    </div>
  </div>
</div>

<!-- PR Details Drawer -->
<div id="prDrawerBackdrop" onclick="closePRDrawer()"
  class="fixed inset-0 z-[999] hidden bg-black/40 opacity-0 transition-opacity duration-300"
  style="display:none;">
</div>
<div id="prDrawer"
  class="fixed right-0 top-0 bottom-0 z-[1000] hidden w-full max-w-3xl bg-ink-light shadow-2xl transition-transform duration-300 translate-x-full overflow-y-auto"
  style="display:none;">
  <div class="sticky top-0 border-b border-border-faint bg-ink-light/95 backdrop-blur-sm px-6 py-4 flex items-start justify-between">
    <div style="flex:1;min-width:0;">
      <p class="font-space-mono text-[11px] uppercase tracking-wider text-muted mb-1">Pull Request</p>
      <h2 id="prDrawerTitle" class="font-bold text-sm text-text-primary break-words" style="word-break:break-word;"></h2>
    </div>
    <button onclick="closePRDrawer()"
      class="ml-4 inline-flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full text-muted-dim transition-colors hover:bg-white/[0.06] hover:text-muted">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>

  <div class="p-6 space-y-6">
    <!-- Description -->
    <div>
      <p class="font-space-mono text-[11px] uppercase tracking-wider text-muted mb-3">Description</p>
      <div id="prDrawerDescription" class="prose dark:prose-invert text-sm leading-relaxed break-words prose-p:my-2 prose-h1:text-lg prose-h2:text-base prose-h3:text-sm prose-code:bg-black/10 dark:prose-code:bg-black/30 prose-code:px-2 prose-code:py-1 prose-code:rounded prose-pre:bg-black/10 dark:prose-pre:bg-black/30 prose-pre:p-3 prose-pre:rounded"></div>
    </div>

    <!-- Comments & Reviews -->
    <div>
      <p class="font-space-mono text-[11px] uppercase tracking-wider text-muted mb-3">Comments & Reviews</p>
      <div id="prDrawerComments" class="space-y-4 text-sm">
        <p class="text-muted-dim italic">Loading comments...</p>
      </div>
    </div>
  </div>
</div>