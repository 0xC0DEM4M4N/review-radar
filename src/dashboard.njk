---
layout: base.njk
title: ReviewRadar Dashboard
---

<div id="dashboardPage" class="min-h-screen pt-14">

  <div class="border-b border-border-subtle bg-ink-light/30 px-8 py-6 max-md:px-4 max-md:py-4">
    <div class="mx-auto flex max-w-[1440px] items-center justify-between max-md:flex-col max-md:items-start max-md:gap-2">
      <div>
        <h1 class="mb-0 font-space-mono text-xl font-bold tracking-tight text-text-primary">Review<span
            class="text-cyan">Radar</span></h1>
        <p class="mt-0.5 text-[13px] text-white/45">Monitor all your pull requests in real-time</p>
      </div>
      <div class="flex items-center gap-2">
        <button onclick="openStatusReport()" title="Status Report"
          class="inline-flex items-center justify-center rounded-full border border-white/15 bg-transparent p-2 text-xs text-white/60 no-underline transition-all duration-150 hover:border-white/35 hover:text-text-primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
            <polyline points="10 9 9 9 8 9"/>
          </svg>
        </button>
        <button onclick="openSettingsModal()" title="Settings"
          class="inline-flex items-center justify-center rounded-full border border-white/15 bg-transparent p-2 text-xs text-white/60 no-underline transition-all duration-150 hover:border-white/35 hover:text-text-primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3"/>
            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 5 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 5 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.6a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div class="mx-auto flex max-w-[1440px] flex-col gap-4 px-8 py-5 max-md:px-4 max-md:py-4">

    <!-- Multi-Repo Selector + Token -->
    <div class="rounded-xl border border-border-faint bg-surface p-4">
      <div class="flex flex-wrap items-end gap-3">
        <div class="relative min-w-[280px] flex-1 max-md:min-w-0" id="repoSelector">
          <label class="mb-1.5 block font-space-mono text-[10px] uppercase tracking-wider text-white/40">Repositories</label>
          <div id="repoSelectorTrigger" onclick="toggleRepoDropdown()"
            class="flex w-full cursor-pointer items-center justify-between rounded-lg border border-border-subtle bg-ink-light px-3.5 py-2.5 font-space-mono text-[13px] text-text-primary transition-colors duration-150 hover:border-cyan-mid">
            <span id="repoSelectorText">All repos</span>
            <svg class="opacity-50" width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M3 5L7 9L11 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                stroke-linejoin="round" />
            </svg>
          </div>
          <div id="repoSelectorDropdown"
            class="absolute left-0 right-0 top-[calc(100%+4px)] z-[100] hidden max-h-[280px] overflow-y-auto rounded-lg border border-border-subtle bg-ink-light shadow-lg">
            <div class="sticky top-0 z-[2] border-b border-border-faint bg-ink-light p-2.5">
              <input type="text" id="repoSearch" placeholder="Search repos..." oninput="filterRepoList()"
                onclick="event.stopPropagation()"
                class="w-full rounded-md border border-border-faint bg-white/[0.04] px-3 py-2 font-space-mono text-xs text-text-primary focus:border-cyan focus:outline-none" />
            </div>
            <div id="repoSelectorList" class="p-1">
              <div class="p-4 text-center font-space-mono text-xs text-white/30">No repos saved yet. Load PRs to
                discover repos.</div>
            </div>
            <div class="flex gap-2 border-t border-border-faint p-2">
              <button onclick="selectAllRepos()"
                class="flex-1 rounded-md border border-border-faint bg-surface px-2.5 py-1.5 font-space-mono text-[11px] text-white/60 transition-all duration-150 hover:bg-white/[0.06] hover:text-text-primary">Select
                All</button>
              <button onclick="clearRepoSelection()"
                class="flex-1 rounded-md border border-border-faint bg-surface px-2.5 py-1.5 font-space-mono text-[11px] text-white/60 transition-all duration-150 hover:bg-white/[0.06] hover:text-text-primary">Clear</button>
              <button onclick="addRepoManually()"
                class="flex-1 rounded-md border border-border-faint bg-surface px-2.5 py-1.5 font-space-mono text-[11px] text-white/60 transition-all duration-150 hover:bg-white/[0.06] hover:text-text-primary">+
                Add</button>
            </div>
          </div>
        </div>
        <button id="loadButton" onclick="loadPRs()" title="Load PRs"
          class="inline-flex h-10 w-10 cursor-pointer items-center justify-center rounded-full border-none bg-cyan text-ink-light transition-all duration-150 hover:-translate-y-px hover:opacity-90">
          <svg id="loadIcon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.3"/>
          </svg>
          <span id="loadSpinner" class="loading hidden"></span>
        </button>
      </div>

    </div>
   <div id="statsContainer"
    class="hidden max-w-[1440px] grid-cols-4 gap-3 max-md:grid-cols-2 max-md:px-4 max-md:pb-4"
    style="display: none;">
    <div class="flex items-end gap-3 rounded-xl border border-border-faint bg-surface p-2 justify-center">
      <div class="mb-2 font-space-mono text-[10px] uppercase tracking-wider text-white/40">Total PRs</div>
      <div id="totalCount" class="font-space-mono text-[26px] font-bold text-cyan">0</div>
    </div>
    <div class="flex items-end gap-3 rounded-xl border border-border-faint bg-surface p-2 justify-center">
      <div class="mb-2 font-space-mono text-[10px] uppercase tracking-wider text-white/40">Showing</div>
      <div id="filteredCount" class="font-space-mono text-[26px] font-bold text-text-primary">0</div>
    </div>
    <div class="flex items-end gap-3 rounded-xl border border-border-faint bg-surface p-2 justify-center">
      <div class="mb-2 font-space-mono text-[10px] uppercase tracking-wider text-white/40">Approved</div>
      <div id="statApproved" class="font-space-mono text-[26px] font-bold text-green">0</div>
    </div>
    <div class="flex items-end gap-3 rounded-xl border border-border-faint bg-surface p-2 justify-center">
      <div class="mb-2 font-space-mono text-[10px] uppercase tracking-wider text-white/40">Changes Req.</div>
      <div id="statChanges" class="font-space-mono text-[26px] font-bold text-red">0</div>
    </div>
  </div>

    <!-- Filters & Auto-refresh -->
    <div id="filterControls" class="hidden rounded-xl border border-border-faint bg-surface p-4">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div class="flex flex-wrap items-center gap-2">
          <span class="font-space-mono text-[10px] font-bold uppercase tracking-wider text-white/40">Filter:</span>
          <button
            class="btn-secondary active rounded-full border border-border-faint bg-surface px-3.5 py-1.5 font-space-mono text-[11px] font-semibold text-white/60 transition-all duration-150 hover:bg-white/[0.06] hover:text-text-primary"
            data-filter="all" onclick="setFilter('all')">All PRs</button>
          <button
            class="btn-secondary rounded-full border border-border-faint bg-surface px-3.5 py-1.5 font-space-mono text-[11px] font-semibold text-white/60 transition-all duration-150 hover:bg-white/[0.06] hover:text-text-primary"
            data-filter="owned" onclick="setFilter('owned')">Owned by Me</button>
          <button
            class="btn-secondary rounded-full border border-border-faint bg-surface px-3.5 py-1.5 font-space-mono text-[11px] font-semibold text-white/60 transition-all duration-150 hover:bg-white/[0.06] hover:text-text-primary"
            data-filter="not-owned" onclick="setFilter('not-owned')">Not Owned</button>
          <button
            class="btn-secondary rounded-full border border-border-faint bg-surface px-3.5 py-1.5 font-space-mono text-[11px] font-semibold text-white/60 transition-all duration-150 hover:bg-white/[0.06] hover:text-text-primary"
            data-filter="needs-attention" onclick="setFilter('needs-attention')">🎯 Needs Attention</button>
          <button
            class="btn-secondary rounded-full border border-border-faint bg-surface px-3.5 py-1.5 font-space-mono text-[11px] font-semibold text-white/60 transition-all duration-150 hover:bg-white/[0.06] hover:text-text-primary"
            onclick="clearSort()">Clear Sort</button>
        </div>
        <div class="flex items-center gap-3">
          <label class="flex cursor-pointer items-center gap-1.5 text-xs text-white/50">
            <input type="checkbox" id="autoRefreshToggle" onchange="toggleAutoRefresh()">
            <span>Auto</span>
          </label>
          <input type="number" id="refreshInterval" min="1" max="60" value="5" onchange="updateRefreshInterval()"
            class="w-[50px] rounded-md border border-border-subtle bg-ink-light px-2 py-1.5 font-space-mono text-xs text-text-primary focus:border-cyan focus:outline-none">
          <span class="text-[11px] text-white/30">min</span>
          <label class="flex cursor-pointer items-center gap-1.5 text-xs text-white/50">
            <input type="checkbox" id="notificationsToggle" onchange="toggleNotifications()">
            <span>🔔</span>
          </label>
          <span id="refreshStatus" class="font-space-mono text-[11px] text-white/30">—</span>
          <span id="changesNotif" onclick="clearChangesNotif()" title="Click to dismiss"
            class="hidden cursor-pointer items-center gap-1 rounded-full border border-cyan-mid bg-cyan-dim px-3 py-1 font-space-mono text-[11px] font-semibold text-cyan">
            🔔 <span id="changesCount">0</span>
          </span>
        </div>
      </div>
    </div>
  </div>

  <!-- Status Report Modal Backdrop -->
  <div id="statusReportBackdrop" onclick="closeStatusReport()"
    class="fixed inset-0 z-[1000] hidden bg-black/70 opacity-0 transition-opacity duration-200"
    style="display: none;">
    <div class="flex min-h-full items-center justify-center p-4">
      <div id="statusReportModal" onclick="event.stopPropagation()"
        class="relative w-full max-w-[640px] scale-95 rounded-2xl border border-white/[0.08] bg-ink-light p-6 shadow-2xl opacity-0 transition-all duration-200">
        <!-- Close -->
        <button onclick="closeStatusReport()"
          class="absolute right-4 top-4 inline-flex h-8 w-8 items-center justify-center rounded-full text-white/30 transition-colors hover:bg-white/[0.06] hover:text-white/60">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>

        <!-- Header -->
        <div class="mb-6 text-center">
          <div class="mx-auto mb-3 flex h-10 w-10 items-center justify-center rounded-full bg-cyan/10">
            <svg class="h-5 w-5 text-cyan" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21.21 15.89A10 10 0 1 1 8 2.83"/>
              <path d="M22 12A10 10 0 0 0 12 2v10z"/>
            </svg>
          </div>
          <h2 class="font-space-mono text-sm font-bold tracking-tight text-text-primary">Status Report</h2>
          <p class="mt-1 text-[12px] text-white/40">Current snapshot of your pull requests</p>
        </div>

        <!-- Content -->
        <div id="statusReportContent" class="space-y-6">
          <!-- Injected by JS -->
        </div>
      </div>
    </div>
  </div>

  <!-- Settings Modal Backdrop -->
  <div id="settingsModalBackdrop" onclick="closeSettingsModal()"
    class="absolute inset-0 z-[1000] hidden bg-black/70 opacity-0 transition-opacity duration-200 w-full h-screen top-0"
    style="display: none;">
    <div class="flex min-h-full items-center justify-center p-4 w-full">
      <!-- Settings Modal -->
      <div id="settingsModal" onclick="event.stopPropagation()"
        class="relative w-full max-w-[380px] scale-95 rounded-2xl border border-white/[0.08] bg-ink-light p-4 shadow-2xl opacity-0 transition-all duration-200">
        <!-- Close -->
        <button onclick="closeSettingsModal()"
          class="absolute right-3 top-3 inline-flex h-8 w-8 items-center justify-center rounded-full text-white/30 transition-colors hover:bg-white/[0.06] hover:text-white/60">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>

        <!-- Header -->
        <div class="">
          <div class="mb-6 text-center">
            <div class="mx-auto mb-3 flex h-10 w-10 items-center justify-center rounded-full bg-cyan/10">
              <svg class="h-5 w-5 text-cyan" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/>
              </svg>
            </div>
            <h2 class="font-space-mono text-sm font-bold tracking-tight text-text-primary">GitHub Access Token</h2>
            <p class="mt-1 text-[12px] text-white/40">Required to fetch your pull requests</p>
          </div>

          <!-- Token Input -->
          <div id="modalPatInputWrap" class="space-y-3">
            <div>
              <label class="mb-3 block font-space-mono text-[10px] font-semibold uppercase tracking-wider text-white/40">Personal Access Token</label>
              <input type="password" id="patInput" placeholder="ghp_xxxxxxxxxxxxxxxxxxxx"
                class="w-full rounded-lg border border-border-subtle bg-surface px-3.5 py-2.5 font-space-mono text-[13px] text-text-primary transition-colors duration-150 placeholder:text-white/20 focus:border-cyan focus:outline-none mb-3" />
            </div>
            <button onclick="savePatToken()"
              class="w-full cursor-pointer rounded-lg border-none bg-cyan py-2.5 font-space-mono text-sm font-bold text-ink-light transition-all duration-150 hover:opacity-90">Save Token</button>
            <div class="rounded-lg border border-border-faint bg-surface/50 p-3">
              <p class="mb-3 mt-3 font-space-mono text-[11px] font-semibold text-white/50">How to create a token:</p>
              <ol class="space-y-1 font-space-mono text-[11px] text-white/40">
                <li>1. Go to <a class="text-cyan no-underline hover:underline" href="https://github.com/settings/tokens/new" target="_blank">github.com/settings/tokens/new</a></li>
                <li>2. Select <code class="rounded bg-white/[0.06] px-1 py-0.5 text-cyan">repo</code> scope</li>
                <li>3. Copy and paste the token above</li>
              </ol>
            </div>
          </div>

          <!-- Saved State -->
          <div id="modalPatSavedWrap" class="hidden flex-col items-center gap-3 text-center">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-green/10">
              <svg class="h-5 w-5 text-green" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </div>
            <div>
              <p class="font-space-mono text-sm font-bold text-text-primary">Token Saved</p>
              <p class="mt-0.5 text-[12px] text-white/40">Your GitHub PAT is securely stored</p>
            </div>
            <button onclick="showPatInput()"
              class="cursor-pointer rounded-lg border border-border-faint bg-surface px-4 py-2 font-space-mono text-[11px] text-white/60 transition-all duration-150 hover:bg-white/[0.06] hover:text-text-primary">Update Token</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  
  
  <div class="mx-auto max-w-[1440px] px-8 pb-12 max-md:px-4 max-md:pb-8">
    <div class="overflow-hidden rounded-xl border border-border-faint bg-surface">
      <table id="prTable" class="w-full border-collapse text-[13px] leading-relaxed">
        <thead class=" border-border-transparent bg-ink-light/50">
          <tr>
            <th
              class="sortable cursor-pointer whitespace-nowrap px-3 py-3 text-left font-space-mono text-[10px] font-semibold uppercase tracking-wider text-white/35 select-none hover:bg-white/[0.03]"
              onclick="sortTable('title')">Pull Request</th>
            <th
              class="sortable cursor-pointer whitespace-nowrap px-3 py-3 text-left font-space-mono text-[10px] font-semibold uppercase tracking-wider text-white/35 select-none hover:bg-white/[0.03]"
              onclick="sortTable('author')">Author</th>
            <th
              class="sortable cursor-pointer whitespace-nowrap px-3 py-3 text-left font-space-mono text-[10px] font-semibold uppercase tracking-wider text-white/35 select-none hover:bg-white/[0.03]"
              onclick="sortTable('reviews')">Reviews</th>
            <th
              class="sortable cursor-pointer whitespace-nowrap px-3 py-3 text-left font-space-mono text-[10px] font-semibold uppercase tracking-wider text-white/35 select-none hover:bg-white/[0.03]"
              onclick="sortTable('reviewedByMe')">Reviewed</th>
            <th
              class="sortable cursor-pointer whitespace-nowrap px-3 py-3 text-left font-space-mono text-[10px] font-semibold uppercase tracking-wider text-white/35 select-none hover:bg-white/[0.03]"
              onclick="sortTable('mentions')">Mentions</th>
            <th
              class="sortable cursor-pointer whitespace-nowrap px-3 py-3 text-left font-space-mono text-[10px] font-semibold uppercase tracking-wider text-white/35 select-none hover:bg-white/[0.03]"
              onclick="sortTable('labels')">Labels</th>
            <th
              class="sortable cursor-pointer whitespace-nowrap px-3 py-3 text-left font-space-mono text-[10px] font-semibold uppercase tracking-wider text-white/35 select-none hover:bg-white/[0.03]"
              onclick="sortTable('buildStatus')">Build</th>
            <th
              class="sortable cursor-pointer whitespace-nowrap px-3 py-3 text-left font-space-mono text-[10px] font-semibold uppercase tracking-wider text-white/35 select-none hover:bg-white/[0.03]"
              onclick="sortTable('mergeStatus')">Merge</th>
            <th
              class="sortable cursor-pointer whitespace-nowrap px-3 py-3 text-left font-space-mono text-[10px] font-semibold uppercase tracking-wider text-white/35 select-none hover:bg-white/[0.03]"
              onclick="sortTable('updated')">Updated</th>
          </tr>
        </thead>
        <tbody id="prTableBody">
          <tr>
            <td colspan="9" class="px-8 py-16 text-center text-white/40">
              <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-cyan/10">
                <svg class="h-6 w-6 text-cyan animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
                </svg>
              </div>
              <p class="mb-2 font-space-mono text-sm text-text-primary">Loading saved settings...</p>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>
