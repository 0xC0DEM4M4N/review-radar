---
layout: base.njk
title: ReviewRadar Reports
---
<script>document.body.classList.add('rr-app-page');</script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<aside class="rr-sidebar">
  <a href="/dashboard" class="rr-sidebar-icon" title="Dashboard">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="1" y="1" width="6" height="6" rx="1.5" fill="currentColor"/><rect x="9" y="1" width="6" height="6" rx="1.5" fill="currentColor" opacity="0.4"/><rect x="1" y="9" width="6" height="6" rx="1.5" fill="currentColor" opacity="0.4"/><rect x="9" y="9" width="6" height="6" rx="1.5" fill="currentColor" opacity="0.4"/></svg>
  </a>
  <a href="/reports" class="rr-sidebar-icon active" title="Reports">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="2" y="9" width="3" height="5" rx="1" fill="currentColor"/><rect x="6.5" y="5" width="3" height="9" rx="1" fill="currentColor"/><rect x="11" y="2" width="3" height="12" rx="1" fill="currentColor"/></svg>
  </a>
  <div class="rr-sidebar-spacer"></div>
  <a href="/settings" class="rr-sidebar-icon" title="Settings">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06.06A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9"/></svg>
  </a>
</aside>

<div class="rr-main">

  <!-- Header -->

  <div class="rr-header-row">
    <div class="rr-radar-bg" style="background:var(--ink-light);">
      <svg width="26" height="26" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6" stroke="var(--cyan)" stroke-width="1.5" fill="none"/><circle cx="8" cy="8" r="3" fill="var(--cyan)" opacity="0.3"/></svg>
    </div>
    <div style="flex:1;min-width:0;">
      <h1 class="rr-header-title">Status Report</h1>
      <p class="rr-header-sub" id="reportSubtitle">Current snapshot of your pull requests</p>
    </div>
    <div class="rr-header-actions">
      <button id="reportsRefreshBtn" onclick="reportsRefresh()" class="rr-btn-primary">
        <svg id="reportsRefreshIcon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.3"/></svg>
        Refresh
      </button>
    </div>
  </div>

  <!-- Status bar -->
  <div id="reportsStatus" style="display:none;font-family:'Space Mono',monospace;font-size:12px;color:var(--muted);margin-bottom:12px;padding:8px 12px;border-radius:6px;background:rgba(255,255,255,0.03);border:0.5px solid var(--border-faint);"></div>

  <!-- No data / no PAT state -->
  <div id="reportsNoData" style="display:none;text-align:center;padding:80px 32px;">
    <div style="width:56px;height:56px;border-radius:50%;background:var(--cyan-dim);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
      <svg style="color:var(--cyan);" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21.21 15.89A10 10 0 1 1 8 2.83"/><path d="M22 12A10 10 0 0 0 12 2v10z"/></svg>
    </div>
    <p style="font-family:'Space Mono',monospace;font-size:14px;color:var(--text-primary);margin-bottom:8px;">Loading…</p>
    <p style="font-size:13px;color:var(--muted);">Fetching your pull requests from GitHub.</p>
  </div>

  <!-- No PAT state -->
  <div id="reportsNoPat" style="display:none;text-align:center;padding:80px 32px;">
    <div style="width:56px;height:56px;border-radius:50%;background:rgba(245,158,11,0.1);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
      <svg style="color:var(--amber);" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
    </div>
    <p style="font-family:'Space Mono',monospace;font-size:14px;color:var(--text-primary);margin-bottom:8px;">No GitHub token configured</p>
    <p style="font-size:13px;color:var(--muted);margin-bottom:20px;">Add your Personal Access Token in Settings to fetch live data.</p>
    <a href="/settings" class="rr-btn-primary" style="text-decoration:none;">Go to Settings</a>
  </div>

  <!-- Main content grid -->
  <div id="reportsGrid" style="display:none;display:grid;grid-template-columns:1fr;gap:16px;max-width:100%;">

    <!-- Top Metrics Row: Total PRs, Approved, Failing Builds -->
    <h3 class="mb-1 font-space-mono text-[10px] font-bold uppercase tracking-wider text-white/40">Overview</h3>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;">
      <div class="rr-stat" style="background:var(--ink-light);border:0.5px solid var(--border-faint);border-radius:12px;padding:16px;text-align:center;">
        <div style="font-family:'Space Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:0.05em;color:var(--muted);margin-bottom:8px;">Total PRs</div>
        <div id="metricTotalPRs" style="font-family:'Space Mono',monospace;font-size:28px;font-weight:700;color:var(--cyan);">—</div>
      </div>
      <div class="rr-stat" style="background:var(--ink-light);border:0.5px solid var(--border-faint);border-radius:12px;padding:16px;text-align:center;">
        <div style="font-family:'Space Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:0.05em;color:var(--muted);margin-bottom:8px;">Approved</div>
        <div id="metricApproved" style="font-family:'Space Mono',monospace;font-size:28px;font-weight:700;color:var(--green);">—</div>
      </div>
      <div class="rr-stat" style="background:var(--ink-light);border:0.5px solid var(--border-faint);border-radius:12px;padding:16px;text-align:center;">
        <div style="font-family:'Space Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:0.05em;color:var(--muted);margin-bottom:8px;">Failed</div>
        <div id="metricFailingBuilds" style="font-family:'Space Mono',monospace;font-size:28px;font-weight:700;color:var(--red);">—</div>
      </div>
    </div>

    <!-- Reviews Row: No Reviews, 1 Review, 2+ Reviews -->
    <h3 class="mb-1 font-space-mono text-[10px] font-bold uppercase tracking-wider text-white/40">Review Status</h3>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;">
      <div class="rr-stat" style="background:var(--ink-light);border:0.5px solid var(--border-faint);border-radius:12px;padding:16px;text-align:center;">
        <div style="font-family:'Space Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:0.05em;color:var(--muted);margin-bottom:8px;">No Reviews</div>
        <div id="metricNoReviews" style="font-family:'Space Mono',monospace;font-size:28px;font-weight:700;color:var(--amber);">—</div>
      </div>
      <div class="rr-stat" style="background:var(--ink-light);border:0.5px solid var(--border-faint);border-radius:12px;padding:16px;text-align:center;">
        <div style="font-family:'Space Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:0.05em;color:var(--muted);margin-bottom:8px;">1 Review</div>
        <div id="metricOneReview" style="font-family:'Space Mono',monospace;font-size:28px;font-weight:700;color:var(--cyan);">—</div>
      </div>
      <div class="rr-stat" style="background:var(--ink-light);border:0.5px solid var(--border-faint);border-radius:12px;padding:16px;text-align:center;">
        <div style="font-family:'Space Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:0.05em;color:var(--muted);margin-bottom:8px;">2+ Reviews</div>
        <div id="metricManyReviews" style="font-family:'Space Mono',monospace;font-size:28px;font-weight:700;color:var(--green);">—</div>
      </div>
    </div>


    <!-- Last Updated Row: <24hrs, <7 days, >7 days -->
     <h3 class="mb-1 font-space-mono text-[10px] font-bold uppercase tracking-wider text-white/40">Last Updated</h3>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;">
      <div class="rr-stat" style="background:var(--ink-light);border:0.5px solid var(--border-faint);border-radius:12px;padding:16px;text-align:center;">
        <div style="font-family:'Space Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:0.05em;color:var(--muted);margin-bottom:8px;">&lt; 24 HRS</div>
        <div id="metricLt24h" style="font-family:'Space Mono',monospace;font-size:28px;font-weight:700;color:var(--green);">—</div>
      </div>
      <div class="rr-stat" style="background:var(--ink-light);border:0.5px solid var(--border-faint);border-radius:12px;padding:16px;text-align:center;">
        <div style="font-family:'Space Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:0.05em;color:var(--muted);margin-bottom:8px;">&lt; 7 DAYS</div>
        <div id="metricLt7d" style="font-family:'Space Mono',monospace;font-size:28px;font-weight:700;color:var(--cyan);">—</div>
      </div>
      <div class="rr-stat" style="background:var(--ink-light);border:0.5px solid var(--border-faint);border-radius:12px;padding:16px;text-align:center;">
        <div style="font-family:'Space Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:0.05em;color:var(--muted);margin-bottom:8px;">&gt; 7 DAYS</div>
        <div id="metricGt7d" style="font-family:'Space Mono',monospace;font-size:28px;font-weight:700;color:var(--amber);">—</div>
      </div>
    </div>

  <h3 class="mb-1 font-space-mono text-[10px] font-bold uppercase tracking-wider text-white/40">Visualisations</h3>
    <!-- Two column layout for charts -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
      <!-- Open PRs by Person (Horizontal Bar Chart) -->
      <div class="rr-stat" style="background:var(--ink-light);border:0.5px solid var(--border-faint);border-radius:12px;padding:20px;">
        <div class="rr-stat-label" style="margin-bottom:14px;">Open PRs by Person</div>
        <div id="chartPersonContainer" style="min-height:240px;"></div>
      </div>

      <!-- PR by Status (Pie Chart) -->
      <div class="rr-stat" style="background:var(--ink-light);border:0.5px solid var(--border-faint);border-radius:12px;padding:20px;">
        <div class="rr-stat-label" style="margin-bottom:14px;">PR by Status</div>
        <div style="position:relative;height:200px;"><canvas id="chartStatus"></canvas></div>
      </div>
    </div>

    <!-- PRs by Label (Horizontal Bar Chart) - Full Width -->
    <div class="rr-stat" style="background:var(--ink-light);border:0.5px solid var(--border-faint);border-radius:12px;padding:20px;">
      <div class="rr-stat-label" style="margin-bottom:14px;">PRs by Label</div>
      <div id="chartLabelsContainer" style="min-height:200px;"></div>
    </div>

  </div>

</div>

<script>
(function() {
  const CHART_COLORS = ['#22d3ee','#22c55e','#f59e0b','#ef4444','#8b5cf6','#06b6d4','#10b981','#f97316'];

  const theme = localStorage.getItem('reviewradar-theme') || 'dark';
  if (theme === 'light') {
    document.documentElement.classList.add('light-mode');
    Chart.defaults.color = 'rgba(0,0,0,0.5)';
    Chart.defaults.borderColor = 'rgba(0,0,0,0.06)';
  } else {
    Chart.defaults.color = 'rgba(255,255,255,0.45)';
    Chart.defaults.borderColor = 'rgba(255,255,255,0.06)';
  }
  Chart.defaults.font.family = "'Space Mono', monospace";
  Chart.defaults.font.size = 11;

  let charts = {};

  function destroyCharts() {
    Object.values(charts).forEach(c => { try { c.destroy(); } catch(e) {} });
    charts = {};
  }

  function setStatus(msg, isError) {
    const el = document.getElementById('reportsStatus');
    if (!el) return;
    el.textContent = msg;
    el.style.color = isError ? 'var(--red)' : 'var(--muted)';
    el.style.display = msg ? 'block' : 'none';
  }

  function setLoading(on) {
    const btn = document.getElementById('reportsRefreshBtn');
    const icon = document.getElementById('reportsRefreshIcon');
    if (btn) btn.disabled = on;
    if (icon) icon.style.opacity = on ? '0.5' : '1';
  }

  async function ghFetch(url, pat) {
    const res = await fetch(url, {
      headers: { Authorization: `token ${pat}`, Accept: 'application/vnd.github.v3+json' }
    });
    if (!res.ok) throw new Error(`GitHub ${res.status}: ${url}`);
    return res.json();
  }

  async function fetchRepoPRs(repo, pat) {
    const prs = [];
    for (let page = 1; page <= 5; page++) {
      try {
        const data = await ghFetch(
          `https://api.github.com/repos/${repo}/pulls?state=open&per_page=100&page=${page}&sort=updated&direction=desc`,
          pat
        );
        if (!Array.isArray(data) || data.length === 0) break;
        prs.push(...data);
        if (data.length < 100) break;
      } catch(e) { console.warn('Repo fetch error', repo, e.message); break; }
    }
    return prs;
  }

  async function fetchUserSearchPRs(pat) {
    const prs = [];
    try {
      const user = await ghFetch('https://api.github.com/user', pat);
      for (let page = 1; page <= 3; page++) {
        const data = await ghFetch(
          `https://api.github.com/search/issues?q=type:pr+involves:${user.login}+state:open&per_page=100&page=${page}&sort=updated&order=desc`,
          pat
        );
        if (!data.items || data.items.length === 0) break;
        prs.push(...data.items);
        if (data.items.length < 100) break;
      }
    } catch(e) { console.warn('User search error', e.message); }
    return prs;
  }

  async function fetchReviews(pr, pat) {
    try {
      const repoMatch = (pr.repository_url || pr.url || '').match(/repos\/([^/]+\/[^/]+)/);
      if (!repoMatch || !pr.number) return [];
      const data = await ghFetch(
        `https://api.github.com/repos/${repoMatch[1]}/pulls/${pr.number}/reviews`, pat
      );
      return Array.isArray(data) ? data : [];
    } catch(e) { return []; }
  }

  async function fetchBuildStatus(pr, pat) {
    try {
      if (!pr.head || !pr.head.sha) return { state: 'unknown', conclusion: null };
      
      const repoMatch = (pr.repository_url || pr.url || '').match(/repos\/([^/]+\/[^/]+)/);
      if (!repoMatch) return { state: 'unknown', conclusion: null };
      
      const checksResponse = await fetch(
        `https://api.github.com/repos/${repoMatch[1]}/commits/${pr.head.sha}/check-runs`,
        { headers: { Authorization: `token ${pat}`, Accept: 'application/vnd.github.v3+json' } }
      );
      
      let buildStatus = { state: 'unknown', conclusion: null };
      if (checksResponse.ok) {
        const checksData = await checksResponse.json();
        if (checksData.check_runs && checksData.check_runs.length > 0) {
          const statuses = checksData.check_runs.map((run) => run.status);
          const conclusions = checksData.check_runs.map((run) => run.conclusion).filter((c) => c);
          
          if (statuses.includes('in_progress') || statuses.includes('queued')) {
            buildStatus.state = 'in_progress';
          } else if (statuses.every((s) => s === 'completed')) {
            if (conclusions.includes('failure') || conclusions.includes('cancelled')) {
              buildStatus.state = 'failure';
            } else if (conclusions.every((c) => c === 'success' || c === 'neutral' || c === 'skipped')) {
              buildStatus.state = 'success';
            } else {
              buildStatus.state = 'pending';
            }
          } else {
            buildStatus.state = 'in_progress';
          }
          buildStatus.conclusion = conclusions[0] || null;
        }
      }
      return buildStatus;
    } catch(e) { return { state: 'unknown', conclusion: null }; }
  }

  async function fetchLivePRs(pat) {
    const allRepos = getStoredRepos();
    const selectedRepos = getSelectedRepos();
    
    // Use selected repos if any are selected, otherwise use all repos
    const repos = selectedRepos.length > 0 ? selectedRepos : allRepos;
    let rawPRs = [];

    if (repos.length > 0) {
      setStatus(`Fetching PRs from ${repos.length} repo${repos.length !== 1 ? 's' : ''}…`);
      const chunks = await Promise.all(repos.map(r => fetchRepoPRs(r, pat)));
      rawPRs = chunks.flat();
    } else {
      setStatus('Fetching your PRs from GitHub…');
      rawPRs = await fetchUserSearchPRs(pat);
    }

    if (rawPRs.length === 0) return [];

    setStatus(`Fetching reviews for ${rawPRs.length} PRs…`);
    const withReviews = [];
    for (let i = 0; i < rawPRs.length; i += 10) {
      const batch = rawPRs.slice(i, i + 10);
      const resolved = await Promise.all(batch.map(pr => fetchReviews(pr, pat).then(reviews => ({ ...pr, reviews }))));
      withReviews.push(...resolved);
      if (i + 10 < rawPRs.length) setStatus(`Fetched reviews ${Math.min(i + 10, rawPRs.length)} / ${rawPRs.length}…`);
    }

    setStatus(`Fetching build status for ${withReviews.length} PRs…`);
    const withBuildStatus = [];
    for (let i = 0; i < withReviews.length; i += 10) {
      const batch = withReviews.slice(i, i + 10);
      const resolved = await Promise.all(batch.map(pr => fetchBuildStatus(pr, pat).then(buildStatus => ({ ...pr, buildStatus }))));
      withBuildStatus.push(...resolved);
      if (i + 10 < withReviews.length) setStatus(`Fetched build status ${Math.min(i + 10, withReviews.length)} / ${withReviews.length}…`);
    }
    return withBuildStatus;
  }

  function getStoredPat() {
    return localStorage.getItem('github-pat') || '';
  }

  function getStoredRepos() {
    try {
      const v = localStorage.getItem('github-repos');
      return v ? JSON.parse(v) : [];
    } catch(e) { return []; }
  }

  function getSelectedRepos() {
    try {
      const v = localStorage.getItem('selected-repos');
      return v ? JSON.parse(v) : [];
    } catch(e) { return []; }
  }

  function stripLargeDataForStorage(prs) {
    return prs.map(pr => ({
      ...pr,
      buildStatus: pr.buildStatus ? { state: pr.buildStatus.state, conclusion: pr.buildStatus.conclusion } : undefined
    }));
  }

  function filterPRsBySelectedRepos(prs) {
    const selectedRepos = getSelectedRepos();
    if (selectedRepos.length === 0) return prs;
    
    return prs.filter(pr => {
      const url = pr.repository_url || pr.url || '';
      const match = url.match(/repos\/([^/]+\/[^/]+)/);
      const repoName = match ? match[1] : null;
      return repoName && selectedRepos.includes(repoName);
    });
  }

  function renderMetrics(prs) {
    const now = Date.now();

    document.getElementById('metricTotalPRs').textContent = prs.length;

    const approved = prs.filter(p => p.reviews?.some(r => r.state === 'APPROVED')).length;
    document.getElementById('metricApproved').textContent = approved;

    const failingBuilds = prs.filter(p => p.buildStatus?.state === 'failure').length;
    document.getElementById('metricFailingBuilds').textContent = failingBuilds;

    const noReviews = prs.filter(p => !p.reviews || p.reviews.length === 0).length;
    document.getElementById('metricNoReviews').textContent = noReviews;

    const oneReview = prs.filter(p => p.reviews && p.reviews.length === 1).length;
    document.getElementById('metricOneReview').textContent = oneReview;

    const manyReviews = prs.filter(p => p.reviews && p.reviews.length >= 2).length;
    document.getElementById('metricManyReviews').textContent = manyReviews;

    const lt24h = prs.filter(p => (now - new Date(p.updated_at || 0).getTime()) / (1000 * 60 * 60) < 24).length;
    document.getElementById('metricLt24h').textContent = lt24h;

    const lt7d = prs.filter(p => {
      const diff = (now - new Date(p.updated_at || 0).getTime()) / (1000 * 60 * 60);
      return diff >= 24 && diff < 168;
    }).length;
    document.getElementById('metricLt7d').textContent = lt7d;

    const gt7d = prs.filter(p => (now - new Date(p.updated_at || 0).getTime()) / (1000 * 60 * 60) >= 168).length;
    document.getElementById('metricGt7d').textContent = gt7d;
  }

  function renderPersonChart(prs) {
    const byPerson = {};
    prs.forEach(pr => {
      const author = pr.user?.login || 'unknown';
      byPerson[author] = (byPerson[author] || 0) + 1;
    });

    const sorted = Object.entries(byPerson).sort((a, b) => b[1] - a[1]).slice(0, 16);
    if (sorted.length === 0) {
      document.getElementById('chartPersonContainer').innerHTML = '<p style="text-align:center;padding:60px;font-size:12px;color:var(--muted-dim);">No PR authors found</p>';
      return;
    }

    const html = `
      <div style="display:flex;flex-direction:column;gap:8px;">
        ${sorted.map((e, i) => {
          const pct = (e[1] / Math.max(...sorted.map(x => x[1]))) * 100;
          return `
            <div style="display:flex;align-items:center;gap:12px;">
              <div style="font-family:'Space Mono',monospace;font-size:11px;color:var(--muted-dim);min-width:140px;text-align:right;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${e[0].substring(0, 20)}</div>
              <div style="flex:1;height:18px;background:rgba(34,211,238,0.2);border-radius:3px;overflow:hidden;position:relative;">
                <div style="height:100%;background:var(--cyan);width:${pct}%;border-radius:3px;"></div>
              </div>
              <div style="font-family:'Space Mono',monospace;font-size:11px;color:var(--text-primary);min-width:30px;text-align:right;">${e[1]}</div>
            </div>
          `;
        }).join('')}
      </div>
    `;
    document.getElementById('chartPersonContainer').innerHTML = html;
  }

  function renderLabelsChart(prs) {
    const byLabel = {};
    prs.forEach(pr => (pr.labels || []).forEach(l => {
      byLabel[l.name] = (byLabel[l.name] || 0) + 1;
    }));

    const sorted = Object.entries(byLabel).sort((a, b) => b[1] - a[1]).slice(0, 10);
    if (sorted.length === 0) {
      document.getElementById('chartLabelsContainer').innerHTML = '<p style="text-align:center;padding:60px;font-size:12px;color:var(--muted-dim);">No labels found</p>';
      return;
    }

    const html = `
      <div style="display:flex;flex-direction:column;gap:8px;">
        ${sorted.map((e, i) => {
          const pct = (e[1] / Math.max(...sorted.map(x => x[1]))) * 100;
          return `
            <div style="display:flex;align-items:center;gap:12px;">
              <div style="font-family:'Space Mono',monospace;font-size:11px;color:var(--muted-dim);min-width:100px;text-align:right;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${e[0].substring(0, 16)}</div>
              <div style="flex:1;height:18px;background:rgba(245,158,11,0.2);border-radius:3px;overflow:hidden;position:relative;">
                <div style="height:100%;background:var(--amber);width:${pct}%;border-radius:3px;"></div>
              </div>
              <div style="font-family:'Space Mono',monospace;font-size:11px;color:var(--text-primary);min-width:30px;text-align:right;">${e[1]}</div>
            </div>
          `;
        }).join('')}
      </div>
    `;
    document.getElementById('chartLabelsContainer').innerHTML = html;
  }

  function renderStatusChart(prs) {
    const statusCounts = { Open: 0, 'In review': 0, Approved: 0, Blocked: 0, Draft: 0 };
    prs.forEach(pr => {
      const reviews = pr.reviews || [];
      const hasApproval = reviews.some(r => r.state === 'APPROVED');
      const hasChanges = reviews.some(r => r.state === 'CHANGES_REQUESTED');
      const mergeConflict = pr.mergeable_state === 'dirty' || pr.mergeable === false;
      
      if (hasChanges || mergeConflict) statusCounts['Blocked']++;
      else if (hasApproval) statusCounts['Approved']++;
      else if (reviews.length > 0) statusCounts['In review']++;
      else if (pr.draft) statusCounts['Draft']++;
      else statusCounts['Open']++;
    });

    const statusEntries = Object.entries(statusCounts).filter(([,v]) => v > 0);
    if (statusEntries.length === 0) return;

    const el = document.getElementById('chartStatus');
    if (charts.status) charts.status.destroy();
    charts.status = new Chart(el, {
      type: 'pie',
      data: {
        labels: statusEntries.map(e => e[0]),
        datasets: [{
          data: statusEntries.map(e => e[1]),
          backgroundColor: CHART_COLORS.slice(0, statusEntries.length).map(c => c + 'cc'),
          borderColor: 'rgba(255,255,255,0.06)',
          borderWidth: 1
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            position: 'right',
            labels: { boxWidth: 10, padding: 12 }
          }
        }
      }
    });
  }

  async function loadData() {
    setLoading(true);
    setStatus('');

    const pat = getStoredPat();
    const raw = localStorage.getItem('reviewradar-prs');
    let cached = [];
    try { cached = raw ? JSON.parse(raw) : []; } catch(e) {}

    // If we have cached data, show it immediately and hide error states
    if (cached.length > 0) {
      const filteredCached = filterPRsBySelectedRepos(cached);
      if (filteredCached.length > 0) {
        document.getElementById('reportsNoData').style.display = 'none';
        document.getElementById('reportsNoPat').style.display = 'none';
        document.getElementById('reportsGrid').style.display = 'grid';
        showData(filteredCached);
        setLoading(false);
        
        // If no PAT, just use cached data
        if (!pat) {
          setStatus('Using cached data — add a GitHub token in Settings to fetch live data.');
          return;
        }
        
        // If we have a PAT, try to fetch fresh data in the background
      } else {
        // Cached data exists but no repos selected
        document.getElementById('reportsNoData').style.display = 'block';
        document.getElementById('reportsGrid').style.display = 'none';
        document.getElementById('reportsNoPat').style.display = 'none';
        setLoading(false);
        return;
      }
    } else if (!pat) {
      // No cached data and no PAT
      setLoading(false);
      document.getElementById('reportsNoData').style.display = 'none';
      document.getElementById('reportsNoPat').style.display = 'block';
      document.getElementById('reportsGrid').style.display = 'none';
      return;
    }

    // Fetch fresh data if we have a PAT
    try {
      const prs = await fetchLivePRs(pat);
      if (prs.length > 0) {
        try {
          const stripped = stripLargeDataForStorage(prs);
          localStorage.setItem('reviewradar-prs', JSON.stringify(stripped));
        } catch(storageError) {
          console.warn('Storage quota exceeded, using fetched data without caching:', storageError.message);
        }
        document.getElementById('reportsNoData').style.display = 'none';
        document.getElementById('reportsNoPat').style.display = 'none';
        document.getElementById('reportsGrid').style.display = 'grid';
        showData(prs);
      } else {
        setStatus('No open PRs found', false);
        document.getElementById('reportsNoData').style.display = 'block';
        document.getElementById('reportsNoPat').style.display = 'none';
        document.getElementById('reportsGrid').style.display = 'none';
      }
    } catch(e) {
      console.error('Load error:', e);
      setStatus('Error loading data: ' + e.message, true);
      document.getElementById('reportsNoData').style.display = 'block';
      document.getElementById('reportsNoPat').style.display = 'none';
      document.getElementById('reportsGrid').style.display = 'none';
    }

    setLoading(false);
  }

  function showData(prs) {
    document.getElementById('reportsNoData').style.display = 'none';
    document.getElementById('reportsNoPat').style.display = 'none';
    document.getElementById('reportsGrid').style.display = 'grid';

    const repos = [...new Set(prs.map(pr => {
      const url = pr.repository_url || pr.url || '';
      const m = url.match(/repos\/([^/]+\/[^/]+)/);
      return m ? m[1] : null;
    }).filter(Boolean))];

    const repoLabel = repos.length > 0 ? repos.join(', ').slice(0, 80) + (repos.join(', ').length > 80 ? '…' : '') : 'all repos';
    document.getElementById('reportSubtitle').textContent = `${prs.length} open PRs · ${repoLabel}`;

    renderMetrics(prs);
    renderPersonChart(prs);
    renderLabelsChart(prs);
    renderStatusChart(prs);
  }

  window.reportsRefresh = loadData;

  loadData();
})();
</script>
