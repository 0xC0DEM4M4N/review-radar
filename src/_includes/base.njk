<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/favicon-16.png">
  <script>
    (function() {
      var saved = localStorage.getItem('reviewradar-theme');
      var prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
      var theme = saved || (prefersLight ? 'light' : 'dark');
      if (theme === 'light') document.documentElement.classList.add('light-mode');
    })();
  </script>
  <link rel="stylesheet" href="/styles.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link
    href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,300&display=swap"
    rel="stylesheet">
  <!-- Cloudflare Web Analytics -->
  <script defer src='https://static.cloudflareinsights.com/beacon.min.js'
    data-cf-beacon='{"token": "MY_TOKEN"}'></script>
  <!-- End Cloudflare Web Analytics -->

</head>

<body>

  <div id="statusMessage"
    class="fixed bottom-6 right-6 z-[1000] hidden max-w-[420px] rounded-lg border-l-[3px] pr-4 py-3.5 text-[13px] shadow-md backdrop-blur-sm animate-slide-in">
  </div>

  <nav
    class="fixed top-0 left-0 right-0 z-[200] flex h-14 items-center gap-3 border-b border-border-subtle bg-ink-light/85 px-8 ps-4 backdrop-blur-md">
    <a class="flex items-center gap-2.5 no-underline" href="/">
      <img class="h-7 w-7 shrink-0" src="/assets/logo.svg" alt="ReviewRadar">
      <span class="font-space-mono text-[15px] font-bold tracking-tight text-text-primary">Review<span
          class="text-cyan">Radar</span></span>
    </a>
    <div class="flex-1"></div>
    <ul class="flex list-none gap-6">
      <li><a href="/" class="text-[13px] text-white/50 no-underline transition-colors duration-150 hover:text-text-primary">Home</a></li>
      <li><a href="/guide" class="text-[13px] text-white/50 no-underline transition-colors duration-150 hover:text-text-primary">Guide</a></li>
    </ul>
    {% if page.url != '/dashboard/' %}
    <a href="/dashboard"
      class="cursor-pointer rounded-full border-none bg-cyan px-5 py-2 font-space-mono text-xs font-bold text-ink-light no-underline transition-opacity duration-150 hover:opacity-85">Open Dashboard →</a>
    {% endif %}
    <button id="themeToggle"
      class="cursor-pointer rounded-full border border-border-subtle bg-transparent px-3 py-[7px] font-space-mono text-[11px] text-muted"
      onclick="toggleTheme()" title="Dark mode — click for light">🌙</button>
    <a href="https://github.com/0xC0DEM4M4N/review-radar" target="_blank"
      class="ml-2 text-white/50 hover:text-text-primary transition-colors" title="View on GitHub">
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
        <path
          d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
      </svg>
    </a>
  </nav>

  {{ content | safe }}

  <footer
    class="flex items-center justify-between border-t border-white/[0.06] px-12 py-6 max-md:flex-col max-md:gap-2 max-md:text-center max-md:px-5">
    <p class="font-space-mono text-xs text-white/20">© 2026 ReviewRadar · MIT License · Built for developers</p>
    <p class="font-space-mono text-xs text-white/20">Open Source · Zero Backend · Client-side Only</p>
  </footer>

  <script type="module" src="/main.js"></script>
</body>

</html>
