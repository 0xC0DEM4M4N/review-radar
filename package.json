{
  "name": "reviewradar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build.js",
    "dev": "npx esbuild js/main.js --bundle --outfile=dist/main.js --sourcemap --watch",
