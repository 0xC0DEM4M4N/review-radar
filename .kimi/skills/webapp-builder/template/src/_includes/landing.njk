<div id="landingPage" class="min-h-screen pt-14">

  <section class="mx-auto grid min-h-[calc(100vh-56px)] max-w-[1280px] grid-cols-2 items-center gap-0 px-12 pb-20 pt-[60px] max-lg:grid-cols-1 max-lg:text-center">
    <div class="pr-12 max-lg:pr-0">
      <div class="mb-7 inline-flex items-center gap-2 rounded-full border border-cyan-mid bg-cyan-dim px-3.5 py-1 font-space-mono text-[11px] uppercase tracking-wider text-cyan animate-fade-up">
        <span class="h-1.5 w-1.5 rounded-full bg-cyan"></span> Free &amp; open source
      </div>
      <h1 class="mb-6 font-space-mono text-[clamp(36px,4vw,56px)] font-bold leading-tight tracking-tight text-text-primary animate-fade-up">
        Your tool.<br><span class="text-cyan">On radar.</span></h1>
      <p class="mb-10 max-w-[440px] text-lg font-light leading-relaxed text-white/55 max-lg:mx-auto animate-fade-up">
        A concise description of what your tool does. Keep it punchy.</p>
      <div class="mb-12 flex flex-wrap items-center gap-3.5 animate-fade-up">
        <button class="inline-flex items-center gap-1.5 rounded-full border-none bg-cyan px-7 py-3.5 font-space-mono text-[13px] font-bold text-ink-light no-underline transition-all duration-150 hover:-translate-y-px hover:opacity-90" onclick="showDashboard()">Open the dashboard →</button>
        <a class="inline-flex items-center gap-1.5 rounded-full border border-white/15 bg-transparent px-6 py-3.5 text-sm text-white/60 no-underline transition-all duration-150 hover:border-white/35 hover:text-text-primary" href="{{ githubUrl }}" target="_blank">View on GitHub</a>
      </div>
    </div>

    <div class="relative flex items-center justify-center animate-fade-up max-lg:hidden">
      <div class="relative h-[440px] w-[440px]">
        <img id="heroImg" class="h-full w-full" src="assets/hero.svg" alt="Hero illustration">
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-[1280px] border-t border-white/[0.06] px-12 py-[100px] max-md:px-5 max-md:py-[60px]" id="features">
    <div class="mb-4 font-space-mono text-[11px] uppercase tracking-widest text-cyan">Built for developers</div>
    <h2 class="mb-[60px] max-w-[500px] font-space-mono text-4xl font-bold leading-tight tracking-tight text-text-primary">Everything you need.</h2>
    <div class="grid grid-cols-3 gap-6 max-lg:grid-cols-2 max-md:grid-cols-1">
      <div class="rounded-2xl border border-border-faint bg-surface p-7 transition-all duration-200 hover:border-cyan/20 hover:bg-cyan/[0.03]">
        <div class="mb-[18px] flex h-10 w-10 items-center justify-center rounded-[10px] border border-cyan-mid bg-cyan-dim">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7" stroke="#22d3ee" stroke-width="1.5" stroke-opacity="0.5"/><circle cx="10" cy="10" r="3.5" stroke="#22d3ee" stroke-width="1.5"/></svg>
        </div>
        <h3 class="mb-2.5 font-space-mono text-sm font-bold text-text-primary">Feature One</h3>
        <p class="text-sm leading-relaxed text-white/45">Describe your first feature here.</p>
      </div>
      <div class="rounded-2xl border border-border-faint bg-surface p-7 transition-all duration-200 hover:border-cyan/20 hover:bg-cyan/[0.03]">
        <div class="mb-[18px] flex h-10 w-10 items-center justify-center rounded-[10px] border border-cyan-mid bg-cyan-dim">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><rect x="3" y="3" width="14" height="14" rx="3" fill="none" stroke="#22d3ee" stroke-width="1.4"/></svg>
        </div>
        <h3 class="mb-2.5 font-space-mono text-sm font-bold text-text-primary">Feature Two</h3>
        <p class="text-sm leading-relaxed text-white/45">Describe your second feature here.</p>
      </div>
      <div class="rounded-2xl border border-border-faint bg-surface p-7 transition-all duration-200 hover:border-cyan/20 hover:bg-cyan/[0.03]">
        <div class="mb-[18px] flex h-10 w-10 items-center justify-center rounded-[10px] border border-cyan-mid bg-cyan-dim">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2 L12.5 7.5 L18 8.2 L14 12 L15 17.5 L10 14.8 L5 17.5 L6 12 L2 8.2 L7.5 7.5 Z" fill="none" stroke="#22d3ee" stroke-width="1.4" stroke-linejoin="round"/></svg>
        </div>
        <h3 class="mb-2.5 font-space-mono text-sm font-bold text-text-primary">Feature Three</h3>
        <p class="text-sm leading-relaxed text-white/45">Describe your third feature here.</p>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-[1280px] border-t border-white/[0.06] px-12 py-[100px] max-md:px-5 max-md:py-[60px]" id="how-it-works">
    <h2 class="mb-4 font-space-mono text-4xl font-bold tracking-tight text-text-primary">How it works</h2>
    <p class="mb-12 text-lg text-white/45">Get started in 3 simple steps</p>
    <div class="flex max-w-[700px] flex-col gap-8">
      <div class="flex items-start gap-5">
        <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full border border-cyan-mid bg-cyan-dim font-space-mono text-base font-bold text-cyan">1</div>
        <div>
          <h3 class="mb-1.5 font-space-mono text-base font-bold text-text-primary">Step One</h3>
          <p class="text-sm leading-relaxed text-white/45">Describe the first step.</p>
        </div>
      </div>
      <div class="flex items-start gap-5">
        <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full border border-cyan-mid bg-cyan-dim font-space-mono text-base font-bold text-cyan">2</div>
        <div>
          <h3 class="mb-1.5 font-space-mono text-base font-bold text-text-primary">Step Two</h3>
          <p class="text-sm leading-relaxed text-white/45">Describe the second step.</p>
        </div>
      </div>
      <div class="flex items-start gap-5">
        <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full border border-cyan-mid bg-cyan-dim font-space-mono text-base font-bold text-cyan">3</div>
        <div>
          <h3 class="mb-1.5 font-space-mono text-base font-bold text-text-primary">Step Three</h3>
          <p class="text-sm leading-relaxed text-white/45">Describe the third step.</p>
        </div>
      </div>
    </div>
  </section>

  <footer class="flex items-center justify-between border-t border-white/[0.06] px-12 py-6 max-md:flex-col max-md:gap-2 max-md:text-center max-md:px-5">
    <p class="font-space-mono text-xs text-white/20">© {{ year }} {{ appName }} · MIT License · Built for developers</p>
    <p class="font-space-mono text-xs text-white/20">Open Source · Zero Backend · Client-side Only</p>
  </footer>
</div>
